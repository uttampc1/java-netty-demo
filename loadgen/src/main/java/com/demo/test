// src/views/settingsLibrary.js
/**
 * HoldOn — Settings → Activity Library (dedicated screen)
 * 
 * Full-screen view for managing the activity library.
 * Reuses renderLibrarySection() from views/librarySection.js.
 */

import { router } from '../utils/router.js';
import { renderLibrarySection } from './librarySection.js';

export async function renderSettingsLibrary(container) {
  container.innerHTML = `
    <main class="container">
      <header class="screen-header">
        <button class="btn-link" id="back-btn">← Settings</button>
        <h2>Activity Library</h2>
        <div class="header-spacer"></div>
      </header>

      <section class="settings-section">
        <div class="settings-card" id="library-card"></div>
      </section>
    </main>
  `;

  container.querySelector('#back-btn').addEventListener('click', () => {
    router.navigate('/settings');
  });

  const libraryCard = container.querySelector('#library-card');
  await renderLibrarySection(libraryCard);
}

// src/views/settings.js - entire content
/**
 * HoldOn — Settings View
 * 
 * Top-level settings screen accessed from home (gear icon).
 * Sections:
 *   - Activity Library (navigation row → dedicated screen)
 *   - Cue Defaults                                          ⏳ 1.4.F.3.A
 *   - Data (export/import/reset)                            ⏳ 1.4.F.3.B
 *   - About                                                 ⏳ 1.4.F.3.C
 */

import { router } from '../utils/router.js';
import { getAllActivities } from '../db/store.js';

export async function renderSettings(container) {
  const activities = await getAllActivities();
  const activityCount = activities.length;

  container.innerHTML = `
    <main class="container">
      <header class="screen-header">
        <button class="btn-link" id="back-btn">← Back</button>
        <h2>Settings</h2>
        <div class="header-spacer"></div>
      </header>

      <section class="settings-section">
        <h3 class="settings-section-title">Activity Library</h3>
        <div class="settings-card">
          <button type="button" class="settings-nav-row" id="library-nav">
            <span class="settings-nav-label">Activity Library</span>
            <span class="settings-nav-meta">
              <span class="settings-nav-count">${activityCount}</span>
              <span class="settings-nav-chevron">›</span>
            </span>
          </button>
        </div>
      </section>

      <section class="settings-section">
        <h3 class="settings-section-title">Cue Defaults</h3>
        <div class="settings-card">
          <p class="muted settings-placeholder">Cue settings coming in Step 1.4.F.3.A.</p>
        </div>
      </section>

      <section class="settings-section">
        <h3 class="settings-section-title">Data</h3>
        <div class="settings-card">
          <p class="muted settings-placeholder">Export / import coming in Step 1.4.F.3.B.</p>
        </div>
      </section>

      <section class="settings-section">
        <h3 class="settings-section-title">About</h3>
        <div class="settings-card">
          <p class="muted settings-placeholder">About info coming in Step 1.4.F.3.C.</p>
        </div>
      </section>
    </main>
  `;

  container.querySelector('#back-btn').addEventListener('click', () => router.navigate('/'));
  container.querySelector('#library-nav').addEventListener('click', () => {
    router.navigate('/settings/library');
  });
}

/* === Settings Navigation Row (iOS-style) === */

.settings-nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background: none;
  border: none;
  padding: 14px 16px;
  font-family: inherit;
  font-size: 16px;
  color: var(--text);
  cursor: pointer;
  text-align: left;
  transition: background-color 0.15s ease;
  -webkit-tap-highlight-color: transparent;
}

.settings-nav-row:hover {
  background-color: rgba(0, 0, 0, 0.03);
}

@media (prefers-color-scheme: dark) {
  .settings-nav-row:hover {
    background-color: rgba(255, 255, 255, 0.04);
  }
}

.settings-nav-row:active {
  background-color: rgba(0, 0, 0, 0.06);
}

@media (prefers-color-scheme: dark) {
  .settings-nav-row:active {
    background-color: rgba(255, 255, 255, 0.08);
  }
}

.settings-nav-label {
  font-weight: 500;
  color: var(--text);
}

.settings-nav-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--text-muted);
}

.settings-nav-count {
  font-size: 15px;
  font-weight: 400;
  color: var(--text-muted);
}

.settings-nav-chevron {
  font-size: 20px;
  font-weight: 300;
  color: var(--text-muted);
  line-height: 1;
}
