ffmpeg -f lavfi -i "testsrc=duration=60:size=320x240:rate=30" \
       -f lavfi -i "sine=frequency=440:duration=60" \
       -c:v libx264 -profile:v baseline -level 3.0 -pix_fmt yuv420p \
       -c:a aac -b:a 96k -ar 44100 \
       -movflags frag_keyframe+empty_moov+default_base_moof+separate_moof \
       mms.mp4


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>ManagedMediaSource Wake Test</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, sans-serif; background:#111; color:#eee; padding:16px; padding-top:env(safe-area-inset-top,16px); }
    h1 { font-size:18px; margin-bottom:12px; }
    #player { width:100%; height:30vh; background:#000; border-radius:8px; }
    .beat-row { display:flex; align-items:center; gap:10px; margin:10px 0; }
    #beat { width:18px; height:18px; border-radius:50%; background:#666; transition:background 0.1s; }
    #ct { font-family:monospace; font-size:13px; color:#0f0; }
    .status { text-align:center; padding:12px; border-radius:8px; background:#333; margin:10px 0; font-weight:700; font-size:14px; }
    .status.playing { background:#1b5e20; color:#a5d6a7; }
    .timer { font-size:38px; font-weight:300; text-align:center; font-variant-numeric:tabular-nums; margin:10px 0; }
    button { display:block; width:100%; padding:15px; font-size:16px; font-weight:700; border:none; border-radius:10px; cursor:pointer; margin-bottom:8px; -webkit-tap-highlight-color:transparent; }
    .btn-go { background:#34c759; color:white; }
    .btn-stop { background:#ff3b30; color:white; }
    .log { background:#000; color:#6f6; padding:12px; border-radius:8px; font-family:monospace; font-size:11px; max-height:240px; overflow-y:auto; white-space:pre-wrap; margin-top:10px; }
    .hint { font-size:12px; color:#999; line-height:1.5; margin-top:8px; }
  </style>
</head>
<body>
  <h1>🎬 ManagedMediaSource Wake Test</h1>

  <video id="player" loop playsinline></video>

  <div class="beat-row">
    <div id="beat"></div>
    <div id="ct">currentTime: 0.00</div>
  </div>

  <div class="status" id="status">Stopped</div>
  <div class="timer" id="timer">00:00</div>

  <button class="btn-go" id="go-btn">▶ Start (ManagedMediaSource)</button>
  <button class="btn-stop" id="stop-btn" style="display:none;">⏹ Stop</button>

  <div class="hint">
    Uses ManagedMediaSource (Apple's MSE, what YouTube uses on iOS 17+).
    🟢 green = playing. Keep volume down but NOT muted. Pocket phone, wait past auto-lock.
  </div>

  <div class="log" id="log">Ready…</div>

  <script>
    const player = document.getElementById('player');
    const statusEl = document.getElementById('status');
    const timerEl = document.getElementById('timer');
    const logEl = document.getElementById('log');
    const goBtn = document.getElementById('go-btn');
    const stopBtn = document.getElementById('stop-btn');
    const beat = document.getElementById('beat');
    const ct = document.getElementById('ct');

    let startTime=null, timerInterval=null, lastVisible=Date.now();
    let mediaSource=null, sourceBuffer=null, mediaData=null;

    const MIME = 'video/mp4; codecs="avc1.42E01E, mp4a.40.2"';

    function log(m){ const t=new Date().toLocaleTimeString(); logEl.textContent=`[${t}] ${m}\n`+logEl.textContent; }
    function updateTimer(){ if(!startTime)return; const e=Math.floor((Date.now()-startTime)/1000); timerEl.textContent=`${String(Math.floor(e/60)).padStart(2,'0')}:${String(e%60).padStart(2,'0')}`; }

    // Heartbeat
    let lastCT=-1, flip=false;
    setInterval(() => {
      const t = player.currentTime;
      ct.textContent = `currentTime: ${t.toFixed(2)}`;
      if (t !== lastCT && !player.paused) { flip=!flip; beat.style.background = flip?'#0f0':'#080'; }
      else { beat.style.background='#f00'; }
      lastCT = t;
    }, 250);

    async function fetchMedia() {
      log('⬇ Fetching mms.mp4...');
      const resp = await fetch('mms.mp4');
      if (!resp.ok) throw new Error(`fetch failed: ${resp.status}`);
      mediaData = await resp.arrayBuffer();
      log(`✅ Fetched ${(mediaData.byteLength/1024).toFixed(1)} KB`);
    }

    function setupManagedMediaSource() {
      return new Promise((resolve, reject) => {
        // Pick the right constructor — prefer ManagedMediaSource on iOS
        const MMS = window.ManagedMediaSource || window.MediaSource;
        if (!MMS) { reject(new Error('No MediaSource or ManagedMediaSource')); return; }

        const usingManaged = !!window.ManagedMediaSource;
        log(`Using: ${usingManaged ? 'ManagedMediaSource ✅' : 'MediaSource (fallback)'}`);

        if (!MMS.isTypeSupported(MIME)) {
          log(`⚠️ MIME not supported: ${MIME}`);
        } else {
          log(`✅ MIME supported`);
        }

        mediaSource = new MMS();

        // ManagedMediaSource requires the video element to know it can disconnect
        // Set disableRemotePlayback to avoid AirPlay interference
        player.disableRemotePlayback = true;

        const objectURL = URL.createObjectURL(mediaSource);
        player.src = objectURL;

        // ManagedMediaSource uses startstreaming/endstreaming events
        if (usingManaged) {
          mediaSource.addEventListener('startstreaming', () => {
            log('📡 startstreaming event');
          });
          mediaSource.addEventListener('endstreaming', () => {
            log('📡 endstreaming event');
          });
        }

        mediaSource.addEventListener('sourceopen', () => {
          log('📂 sourceopen');
          try {
            URL.revokeObjectURL(objectURL);
            sourceBuffer = mediaSource.addSourceBuffer(MIME);
            log('✅ SourceBuffer created');

            sourceBuffer.addEventListener('updateend', () => {
              log('✅ chunk appended, buffered ranges: ' + (sourceBuffer.buffered.length));
              if (sourceBuffer.buffered.length > 0) {
                log(`   buffered: 0 → ${sourceBuffer.buffered.end(0).toFixed(1)}s`);
              }
              resolve();
            }, { once: true });

            sourceBuffer.addEventListener('error', () => log('❌ SourceBuffer error'));

            log('📡 appending media data...');
            sourceBuffer.appendBuffer(mediaData);
          } catch (err) {
            reject(err);
          }
        }, { once: true });

        mediaSource.addEventListener('error', () => log('❌ MediaSource error'));
        mediaSource.addEventListener('sourceended', () => log('📂 sourceended'));
      });
    }

    function setupMediaSession() {
      if (!('mediaSession' in navigator)) { log('⚠️ no mediaSession'); return; }
      navigator.mediaSession.metadata = new MediaMetadata({
        title: 'HoldOn Workout', artist: 'Keep Awake', album: 'Exercise'
      });
      navigator.mediaSession.playbackState = 'playing';
      navigator.mediaSession.setActionHandler('play', () => player.play());
      navigator.mediaSession.setActionHandler('pause', () => player.pause());
      log('✅ MediaSession configured');
    }

    async function start() {
      try {
        goBtn.disabled = true;
        log('--- ManagedMediaSource setup ---');
        log(`ManagedMediaSource available: ${'ManagedMediaSource' in window}`);

        if (!mediaData) await fetchMedia();
        await setupManagedMediaSource();

        player.muted = false;
        player.volume = 1.0;
        player.loop = true;

        await player.play();
        setupMediaSession();

        startTime = Date.now();
        timerInterval = setInterval(updateTimer, 250);
        statusEl.textContent = '🎬 ManagedMediaSource playing';
        statusEl.className = 'status playing';
        goBtn.style.display='none'; stopBtn.style.display='block';
        log(`▶ Playing, muted=${player.muted}, paused=${player.paused}`);
      } catch (err) {
        log(`❌ Start failed: ${err.message}`);
        statusEl.textContent = `❌ ${err.message}`;
      } finally {
        goBtn.disabled = false;
      }
    }

    function stop() {
      player.pause();
      if ('mediaSession' in navigator) navigator.mediaSession.playbackState='paused';
      clearInterval(timerInterval); startTime=null;
      timerEl.textContent='00:00';
      statusEl.textContent='Stopped'; statusEl.className='status';
      goBtn.style.display='block'; stopBtn.style.display='none';
      log('⏹ Stopped');
    }

    goBtn.addEventListener('click', start);
    stopBtn.addEventListener('click', stop);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) log('📵 Page hidden (screen locked)');
      else { const h=Math.floor((Date.now()-lastVisible)/1000); log(`📱 Visible (hidden ~${h}s), paused=${player.paused}`); }
      lastVisible=Date.now();
    });

    player.addEventListener('pause', ()=>{ if(startTime) log('⚠️ video PAUSED'); });
    player.addEventListener('playing', ()=> log('▶ playing event'));
    player.addEventListener('waiting', ()=> log('⏳ waiting'));
    player.addEventListener('stalled', ()=> log('⚠️ stalled'));
    player.addEventListener('error', ()=> log(`❌ video error code: ${player.error?.code}`));
    player.addEventListener('loadedmetadata', ()=> log(`📂 metadata: ${player.videoWidth}x${player.videoHeight}, dur=${player.duration?.toFixed(1)}s`));

    log(`ManagedMediaSource: ${'ManagedMediaSource' in window}`);
    log(`MediaSource: ${'MediaSource' in window}`);
    log('Tap Start. Volume down but unmuted.');
  </script>
</body>
</html>
