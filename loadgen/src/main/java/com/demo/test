/**
 * HoldOn — Exercise Editor (Modal)
 * 
 * Three modes:
 *   - 'edit'         : edit an existing exercise snapshot in a routine
 *   - 'create'       : create a new exercise for a routine (with "Save to library" toggle)
 *   - 'editActivity' : edit a library activity directly (or create new if !activity)
 * 
 * Usage:
 *   openExerciseEditor({ mode: 'edit', exercise, onSave: (snap) => {...} });
 *   openExerciseEditor({ mode: 'create', onSave: (snap) => {...} });
 *   openExerciseEditor({ mode: 'editActivity', activity, onSave: (activity) => {...} });
 *   openExerciseEditor({ mode: 'editActivity', onSave: (activity) => {...} }); // create new
 */

export function openExerciseEditor({ mode, exercise, activity, onSave }) {
  const isCreate = mode === 'create';
  const isActivityMode = mode === 'editActivity';
  const isNewActivity = isActivityMode && !activity;
  
  // Working draft (changes only persist on Save)
  // The draft uses the same field names regardless of mode for shared UI.
  // In activity mode, we map back to activity fields on save.
  let draft;
  if (isCreate) {
    draft = {
      id: generateId(),
      sourceActivityId: null,
      snapshotVersion: Date.now(),
      name: '',
      description: '',
      videoUrl: '',
      workDuration: 30,
      restBetweenSets: 10,
      sets: 3,
    };
  } else if (isActivityMode) {
    if (activity) {
      // Editing existing activity — map activity fields to draft fields
      draft = {
        id: activity.id,
        name: activity.name || '',
        description: activity.description || '',
        videoUrl: activity.videoUrl || '',
        workDuration: activity.defaultWorkDuration ?? 30,
        restBetweenSets: activity.defaultRestBetweenSets ?? 10,
        sets: activity.defaultSets ?? 3,
        _originalActivity: activity,  // keep reference for save
      };
    } else {
      // Creating new activity
      draft = {
        id: null,  // will be assigned by createActivity
        name: '',
        description: '',
        videoUrl: '',
        workDuration: 30,
        restBetweenSets: 10,
        sets: 3,
        _originalActivity: null,
      };
    }
  } else {
    // 'edit' mode — exercise snapshot
    draft = { ...exercise };
  }
  
  // Local state for "save to library" toggle (only in 'create' mode)
  let saveToLibrary = isCreate;


//-----
      ${isCreate ? `
        <div class="form-section-divider"></div>
        <div class="form-group checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" id="ex-save-library" checked />
            <span>Save to library for reuse in other routines</span>
          </label>
        </div>
      ` : ''}
      ${isActivityMode ? `
        <div class="form-section-divider"></div>
        <p class="form-hint editor-activity-note">
          These are the default values used when adding this activity to a routine.
          You can override them per-routine.
        </p>
      ` : ''}
    </form>
    
    <div class="editor-actions">
      <button type="button" class="btn btn-secondary" id="ex-cancel">Cancel</button>
      <button type="button" class="btn btn-primary" id="ex-save">
        ${getSaveButtonLabel(mode, isNewActivity)}
      </button>
    </div>
  `;
  
  const modal = openModal({
    title: getModalTitle(mode, isNewActivity),
    content,
  });
  
  wireUpEditor(content, modal, draft, mode, () => saveToLibrary, (v) => { saveToLibrary = v; }, onSave);
}

function getModalTitle(mode, isNewActivity) {
  if (mode === 'create') return 'New Exercise';
  if (mode === 'editActivity') return isNewActivity ? 'New Activity' : 'Edit Activity';
  return 'Edit Exercise';
}

function getSaveButtonLabel(mode, isNewActivity) {
  if (mode === 'create') return 'Add Exercise';
  if (mode === 'editActivity') return isNewActivity ? 'Create Activity' : 'Save Activity';
  return 'Save Changes';
}

// ---- 
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    
    try {
      if (isActivityMode) {
        // Activity mode — map draft back to activity fields and save
        const activityData = {
          name: draft.name,
          description: draft.description,
          videoUrl: draft.videoUrl,
          defaultWorkDuration: draft.workDuration,
          defaultRestBetweenSets: draft.restBetweenSets,
          defaultSets: draft.sets,
        };
        
        let savedActivity;
        if (draft._originalActivity) {
          // Update existing activity (preserve id, isSeeded, tags, metadata, createdAt)
          savedActivity = await updateActivity({
            ...draft._originalActivity,
            ...activityData,
          });
        } else {
          // Create new activity
          savedActivity = await createActivity({
            ...activityData,
            isSeeded: false,
          });
        }
        
        closeModal(modal);
        setTimeout(() => {
          if (typeof onSave === 'function') {
            onSave(savedActivity);
          }
        }, 100);
      } else {
        // Routine snapshot mode ('edit' or 'create')
        // If creating new + "save to library" is checked, create library activity
        if (isCreate && getSaveToLibrary()) {
          const newActivity = await createActivity({
            name: draft.name,
            description: draft.description,
            videoUrl: draft.videoUrl,
            defaultWorkDuration: draft.workDuration,
            defaultRestBetweenSets: draft.restBetweenSets,
            defaultSets: draft.sets,
            isSeeded: false,
          });
          draft.sourceActivityId = newActivity.id;
          draft.snapshotVersion = newActivity.updatedAt;
        }
        
        closeModal(modal);
        setTimeout(() => {
          if (typeof onSave === 'function') {
            onSave(draft, { saveToLibrary: isCreate && getSaveToLibrary() });
          }
        }, 100);
      }
    } catch (err) {
      console.error('Failed to save:', err);
      alert('Failed to save: ' + err.message);
      saveBtn.disabled = false;
      // Restore the right label based on mode
      if (isActivityMode) {
        saveBtn.textContent = draft._originalActivity ? 'Save Activity' : 'Create Activity';
      } else {
        saveBtn.textContent = isCreate ? 'Add Exercise' : 'Save Changes';
      }
    }
  });

