/**
 * Centerline — Offline ready toast
 *
 * Shows once on first launch after the service worker installs.
 * Uses localStorage so it persists across app closes/reopens.
 */

const STORAGE_KEY = 'cl_offline_ready_shown';

export function listenForOfflineReady() {
  if (!('serviceWorker' in navigator)) return;

  // Already shown on a previous launch — skip entirely
  if (localStorage.getItem(STORAGE_KEY)) return;

  navigator.serviceWorker.ready.then(() => {
    // Mark before showing so rapid re-renders don't double-show
    localStorage.setItem(STORAGE_KEY, '1');
    setTimeout(() => showOfflineReadyToast(), 1500);
  });
}

function showOfflineReadyToast() {
  if (document.getElementById('cl-offline-toast')) return;

  const message = 'App ready — open from your Home Screen icon once to enable offline use';

  const toast = document.createElement('div');
  toast.id = 'cl-offline-toast';
  toast.setAttribute('role', 'status');
  toast.setAttribute('aria-live', 'polite');
  toast.innerHTML = `
    <span class="cl-toast-icon">✓</span>
    <span class="cl-toast-msg">${message}</span>
  `;

  Object.assign(toast.style, {
    position:      'fixed',
    bottom:        'calc(24px + env(safe-area-inset-bottom, 0px))',
    left:          '50%',
    transform:     'translateX(-50%) translateY(16px)',
    background:    '#2e7d32',
    color:         '#fff',
    padding:       '10px 18px',
    borderRadius:  '8px',
    fontSize:      '14px',
    fontWeight:    '500',
    display:       'flex',
    alignItems:    'flex-start',
    gap:           '8px',
    zIndex:        '9999',
    opacity:       '0',
    transition:    'opacity 0.3s ease, transform 0.3s ease',
    whiteSpace:    'normal',
    maxWidth:      '320px',
    lineHeight:    '1.4',
    boxShadow:     '0 2px 12px rgba(0,0,0,0.3)',
    pointerEvents: 'none',
  });

  document.body.appendChild(toast);

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      toast.style.opacity = '1';
      toast.style.transform = 'translateX(-50%) translateY(0)';
    });
  });

  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateX(-50%) translateY(8px)';
    setTimeout(() => toast.remove(), 350);
  }, 6000);
}
