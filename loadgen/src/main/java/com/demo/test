    // Use the parent routine ID for the query (single-exercise sessions
    // are stored under the real routineId)
    const queryRoutineId = routine._parentRoutineId || routine.id;
    const candidate = await findResumableSession(queryRoutineId);
    if (candidate) {
      if (isSingleExercise) {
        // Only resume if it was a single-exercise session for THIS specific exercise
        if (candidate.mode === 'single-exercise' && candidate.lastExerciseId === exerciseId) {
          resumeSnapshot = candidate;
        }
