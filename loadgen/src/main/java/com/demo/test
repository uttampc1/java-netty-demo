import * as cheerio from 'cheerio';

const OCLS_URL = 'https://search.ccb.state.or.us/search/ocls_results.asp';

export interface LocksmithResult {
  found: boolean;
  licenseNumber: string;
  name: string;
  status: string;
  address: string;
  expiration: string;
}

export async function searchOregonLocksmith(query: string): Promise<LocksmithResult> {
  const searchQuery = query.replace(/OCLS$/i, '').trim();
  const startTime = Date.now();

  const formData = new URLSearchParams();
  formData.append('search_criteria', searchQuery);

  const res = await fetch(OCLS_URL, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
      'Referer': 'https://search.ccb.state.or.us/search/ocls_search.asp',
    },
    body: formData.toString(),
  });

  if (!res.ok) {
    throw new Error(`Locksmith search returned ${res.status}`);
  }

  const html = await res.text();
  const result = parseResults(html, query);
  const elapsed = Date.now() - startTime;

  console.log(`[OCLS] Search "${query}" → ${result.found ? result.status : 'No Match'} (${elapsed}ms)`);

  return result;
}

function parseResults(html: string, originalQuery: string): LocksmithResult {
  const $ = cheerio.load(html);

  const noResult: LocksmithResult = {
    found: false,
    licenseNumber: originalQuery,
    name: '—',
    status: 'No Match',
    address: '—',
    expiration: '',
  };

  // Find result table rows
  const tables = $('table');
  let resultRow: cheerio.Cheerio<cheerio.Element> | null = null;

  tables.each((_, table) => {
    const rows = $(table).find('tr');
    rows.each((i, row) => {
      if (i === 0) return; // skip header
      const cells = $(row).find('td');
      if (cells.length >= 3) {
        const cellText = cells.eq(0).text().trim();
        if (cellText.includes('OCLS')) {
          resultRow = $(row);
          return false; // break
        }
      }
    });
    if (resultRow) return false; // break
  });

  if (!resultRow) {
    // Check for "no records found" text
    const bodyText = $('body').text().toLowerCase();
    if (bodyText.includes('no records') || bodyText.includes('0 records') || bodyText.includes('no results')) {
      return noResult;
    }

    // Try any table with 3+ columns as fallback
    tables.each((_, table) => {
      const rows = $(table).find('tr');
      if (rows.length > 1) {
        const dataRow = rows.eq(1);
        const cells = dataRow.find('td');
        if (cells.length >= 3) {
          resultRow = dataRow;
          return false;
        }
      }
    });
  }

  if (!resultRow) {
    return noResult;
  }

  const cells = $(resultRow).find('td');

  return {
    found: true,
    licenseNumber: cells.eq(0).text().trim(),
    name: cells.eq(2).text().trim(),
    status: cells.eq(1).text().trim(),
    address: '—',
    expiration: '',
  };
}

