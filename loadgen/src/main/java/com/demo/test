// 3
// Empty routine
console.log(calculateRoutineDuration(null))  // 0
console.log(calculateRoutineDuration({ exercises: [] }))  // 0

// Single exercise, single set
const minimal = {
  exercises: [{ workDuration: 30, sets: 1, restBetweenSets: 10 }],
  restBetweenExercises: 0
};
console.log(calculateRoutineDuration(minimal))  // 33 (prep + 30 work, no rests)

// Zero rests everywhere
const noRest = {
  exercises: [
    { workDuration: 10, sets: 3, restBetweenSets: 0 },
    { workDuration: 20, sets: 2, restBetweenSets: 0 },
  ],
  restBetweenExercises: 0
};
console.log(calculateRoutineDuration(noRest))  // 3 + 30 + 40 = 73

// 4
const { formatDuration, formatDurationCompact } = await import('/src/utils/routineDuration.js')

console.log(formatDuration(0))      // "0 seconds"
console.log(formatDuration(1))      // "1 second"
console.log(formatDuration(45))     // "45 seconds"
console.log(formatDuration(60))     // "1 minute"
console.log(formatDuration(61))     // "1 minute 1 second"
console.log(formatDuration(90))     // "1 minute 30 seconds"
console.log(formatDuration(600))    // "10 minutes"
console.log(formatDuration(863))    // "14 minutes 23 seconds"
console.log(formatDuration(3600))   // "1 hour"
console.log(formatDuration(3720))   // "1 hour 2 minutes"

console.log(formatDurationCompact(45))    // "45s"
console.log(formatDurationCompact(90))    // "1m 30s"
console.log(formatDurationCompact(3720))  // "1h 2m"

// 5
const { getAllRoutines } = await import('/src/db/store.js')
const { calculateRoutineDuration, formatDuration } = await import('/src/utils/routineDuration.js')

const routines = await getAllRoutines()
routines.forEach(r => {
  const sec = calculateRoutineDuration(r)
  console.log(`${r.title}: ${formatDuration(sec)} (${sec}s)`)
})

