@media (prefers-color-scheme: dark) {
  .form-error {
    color: #ff453a;
  }
}

.form-group input.input-error,
.form-group textarea.input-error {
  border-color: #ff3b30;
  box-shadow: 0 0 0 3px rgba(255, 59, 48, 0.12);
}

@media (prefers-color-scheme: dark) {
