import * as cheerio from 'cheerio';

const CCB_URL = 'https://search.ccb.state.or.us/search/';

export interface CCBResult {
  found: boolean;
  licenseNumber: string;
  name: string;
  status: string;
  address: string;
}

export async function searchOregonCCB(query: string): Promise<CCBResult> {
  const searchQuery = query.replace('#', '').trim();

  // Step 1: GET the page to extract ASP.NET tokens
  const pageRes = await fetch(CCB_URL, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
    },
  });

  const pageHtml = await pageRes.text();
  const $page = cheerio.load(pageHtml);

  const viewState = $page('input[name="__VIEWSTATE"]').val() as string;
  const viewStateGen = $page('input[name="__VIEWSTATEGENERATOR"]').val() as string;
  const eventValidation = $page('input[name="__EVENTVALIDATION"]').val() as string;

  if (!viewState || !eventValidation) {
    throw new Error('Failed to extract form tokens from Oregon CCB page');
  }

  // Step 2: POST the search
  const formData = new URLSearchParams();
  formData.append('__EVENTTARGET', '');
  formData.append('__EVENTARGUMENT', '');
  formData.append('__VIEWSTATE', viewState);
  formData.append('__VIEWSTATEGENERATOR', viewStateGen || '');
  formData.append('__EVENTVALIDATION', eventValidation);
  formData.append('ctl00$MainContent$activeToggle', 'All');
  formData.append('ctl00$MainContent$searchBox', searchQuery);
  formData.append('ctl00$MainContent$submitbtn', 'Search');
  formData.append('reCaptchaToken', '');

  const searchRes = await fetch(CCB_URL, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
      'Referer': CCB_URL,
    },
    body: formData.toString(),
  });

  const resultHtml = await searchRes.text();

  // Step 3: Parse results
  return parseSearchResults(resultHtml, searchQuery);
}

function parseSearchResults(html: string, originalQuery: string): CCBResult {
  const $ = cheerio.load(html);

  // Check result count
  const countText = $('#MainContent_basicCountLabel').text().trim();
  const count = parseInt(countText, 10);

  if (!count || count === 0) {
    return {
      found: false,
      licenseNumber: originalQuery,
      name: '—',
      status: 'No Match',
      address: '—',
    };
  }

  // Parse the GridView table
  const table = $('#MainContent_GridView1');
  const firstDataRow = table.find('tr').eq(1); // skip header row
  const cells = firstDataRow.find('td');

  if (cells.length < 4) {
    return {
      found: false,
      licenseNumber: originalQuery,
      name: '—',
      status: 'No Match',
      address: '—',
    };
  }

  return {
    found: true,
    licenseNumber: cells.eq(0).text().trim(),
    name: cells.eq(1).text().trim(),
    status: cells.eq(2).text().trim(),
    address: cells.eq(3).text().trim(),
  };
}



