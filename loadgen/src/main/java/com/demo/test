<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>iOS API Check</title>
  <style>
    body { font-family: -apple-system, monospace; padding: 20px; font-size: 16px; line-height: 1.8; background:#111; color:#0f0; }
    .row { margin: 8px 0; padding: 8px; background:#000; border-radius:6px; }
    .yes { color: #0f0; }
    .no { color: #f66; }
    h1 { font-size: 18px; color: #fff; }
  </style>
</head>
<body>
  <h1>🔍 iOS Media API Check</h1>
  <div id="out">Checking…</div>

  <script>
    const v = document.createElement('video');
    const checks = {
      'MediaSource': 'MediaSource' in window,
      'ManagedMediaSource': 'ManagedMediaSource' in window,
      'WebKitMediaSource': 'WebKitMediaSource' in window,
      'HLS native (vnd.apple.mpegurl)': v.canPlayType('application/vnd.apple.mpegurl') || '(empty)',
      'HLS native (x-mpegURL)': v.canPlayType('application/x-mpegURL') || '(empty)',
      'mediaSession': 'mediaSession' in navigator,
      'wakeLock': 'wakeLock' in navigator,
      'MSE codec h264+aac': ('MediaSource' in window)
          ? MediaSource.isTypeSupported('video/mp4; codecs="avc1.42E01E, mp4a.40.2"')
          : (('ManagedMediaSource' in window)
              ? ManagedMediaSource.isTypeSupported('video/mp4; codecs="avc1.42E01E, mp4a.40.2"')
              : 'n/a'),
    };

    let html = '';
    for (const [k, val] of Object.entries(checks)) {
      const isYes = val === true || (typeof val === 'string' && val !== '(empty)' && val !== '');
      const cls = isYes ? 'yes' : 'no';
      html += `<div class="row"><span class="${cls}">${isYes ? '✅' : '❌'}</span> ${k}: <b>${val}</b></div>`;
    }
    html += `<div class="row" style="color:#888">UA: ${navigator.userAgent}</div>`;
    document.getElementById('out').innerHTML = html;
  </script>
</body>
</html>
