// src/components/dialog.js
/**
 * HoldOn — Branded Dialog Helpers
 * 
 * Promise-based replacements for native confirm() and alert().
 * Match the app's modal design language (dark mode, mobile slide-up, etc.).
 * 
 * Usage:
 *   const ok = await confirmModal({ title: 'Delete?', message: 'Are you sure?' });
 *   if (ok) { ... }
 *   
 *   await alertModal({ title: 'Error', message: 'Something went wrong.' });
 */

import { openModal, closeModal } from './modal.js';

/**
 * Shows a confirmation dialog. Returns a Promise that resolves to true/false.
 * 
 * @param {Object} options
 * @param {string} options.title         - Modal title
 * @param {string} options.message       - Body message (supports basic line breaks via \n)
 * @param {string} [options.confirmLabel='Confirm'] - Label for the confirm button
 * @param {string} [options.cancelLabel='Cancel']   - Label for the cancel button
 * @param {boolean} [options.danger=false]          - If true, confirm button is red
 * @returns {Promise<boolean>}
 */
export function confirmModal({
  title,
  message,
  confirmLabel = 'Confirm',
  cancelLabel = 'Cancel',
  danger = false,
}) {
  return new Promise((resolve) => {
    const content = document.createElement('div');
    content.className = 'dialog-content';
    content.innerHTML = `
      <p class="dialog-message">${formatMessage(message)}</p>
      
      <div class="dialog-actions">
        <button type="button" class="btn btn-secondary" id="dialog-cancel-btn">
          ${escapeHtml(cancelLabel)}
        </button>
        <button type="button" class="btn ${danger ? 'btn-danger' : 'btn-primary'}" id="dialog-confirm-btn">
          ${escapeHtml(confirmLabel)}
        </button>
      </div>
    `;
    
    const modal = openModal({
      title,
      content,
    });
    
    let resolved = false;
    const finish = (result) => {
      if (resolved) return;
      resolved = true;
      closeModal(modal);
      resolve(result);
    };
    
    content.querySelector('#dialog-cancel-btn').addEventListener('click', () => finish(false));
    content.querySelector('#dialog-confirm-btn').addEventListener('click', () => finish(true));
    
    // If user dismisses via backdrop click or Escape, treat as cancel
    const originalOnClose = modal.onClose;
    modal.onClose = () => {
      if (originalOnClose) originalOnClose();
      if (!resolved) {
        resolved = true;
        resolve(false);
      }
    };
    
    // Auto-focus the cancel button by default (safer for destructive actions)
    setTimeout(() => {
      content.querySelector('#dialog-cancel-btn').focus();
    }, 100);
  });
}

/**
 * Shows a simple alert dialog. Returns a Promise that resolves when dismissed.
 * 
 * @param {Object} options
 * @param {string} options.title         - Modal title
 * @param {string} options.message       - Body message (supports basic line breaks via \n)
 * @param {string} [options.buttonLabel='OK'] - Label for the dismiss button
 * @returns {Promise<void>}
 */
export function alertModal({
  title,
  message,
  buttonLabel = 'OK',
}) {
  return new Promise((resolve) => {
    const content = document.createElement('div');
    content.className = 'dialog-content';
    content.innerHTML = `
      <p class="dialog-message">${formatMessage(message)}</p>
      
      <div class="dialog-actions dialog-actions-single">
        <button type="button" class="btn btn-primary" id="dialog-ok-btn">
          ${escapeHtml(buttonLabel)}
        </button>
      </div>
    `;
    
    const modal = openModal({
      title,
      content,
    });
    
    let resolved = false;
    const finish = () => {
      if (resolved) return;
      resolved = true;
      closeModal(modal);
      resolve();
    };
    
    content.querySelector('#dialog-ok-btn').addEventListener('click', finish);
    
    // If user dismisses via backdrop click or Escape, resolve normally
    const originalOnClose = modal.onClose;
    modal.onClose = () => {
      if (originalOnClose) originalOnClose();
      if (!resolved) {
        resolved = true;
        resolve();
      }
    };
    
    setTimeout(() => {
      content.querySelector('#dialog-ok-btn').focus();
    }, 100);
  });
}

function formatMessage(message) {
  if (message == null) return '';
  return escapeHtml(String(message)).replace(/\n/g, '<br>');
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// style
/* === Step 1.4.G.1 — Branded Dialogs (confirm/alert helpers) === */

.dialog-content {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.dialog-message {
  margin: 0;
  font-size: 15px;
  line-height: 1.5;
  color: var(--text);
  word-wrap: break-word;
}

.dialog-actions {
  display: flex;
  gap: 10px;
}

.dialog-actions .btn {
  flex: 1;
}

/* For alert (single OK button), don't stretch full width on desktop */
.dialog-actions-single {
  justify-content: flex-end;
}

.dialog-actions-single .btn {
  flex: 0 1 auto;
  min-width: 100px;
}
