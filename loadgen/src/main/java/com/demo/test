import { NextRequest, NextResponse } from 'next/server';
import { searchOregonCCB } from '@/lib/oregon-ccb';

export async function POST(request: NextRequest) {
  const body = await request.json();
  const { licenseNumber, jurisdiction } = body;

  if (!licenseNumber) {
    return NextResponse.json(
      { error: 'License number is required' },
      { status: 400 }
    );
  }

  const isOregon = jurisdiction?.toLowerCase().includes('oregon');

  if (isOregon) {
    return handleOregonLookup(licenseNumber, jurisdiction);
  }

  // Fall back to simulated data for other states
  return NextResponse.json(getSimulatedResult(licenseNumber, jurisdiction));
}

async function handleOregonLookup(licenseNumber: string, jurisdiction: string) {
  try {
    const ccbResult = await searchOregonCCB(licenseNumber);

    if (!ccbResult.found) {
      return NextResponse.json({
        status: 'No Match',
        sourceStatus: '—',
        name: '—',
        licenseNumber,
        jurisdiction,
        sourceJurisdiction: '—',
        jurisdictionMatch: false,
        expiration: '—',
        source: 'Oregon Construction Contractors Board',
      });
    }

    const sourceStatus = ccbResult.status;
    const negativeStatuses = ['Inactive', 'Suspended', 'Revoked', 'Expired'];
    const isNegative = negativeStatuses.some(
      (s) => sourceStatus.toLowerCase().includes(s.toLowerCase())
    );

    const jurisdictionMatch = jurisdiction.toLowerCase().includes('oregon');

    let finalStatus: string;
    if (isNegative) {
      finalStatus = 'Not Active';
    } else if (!jurisdictionMatch) {
      finalStatus = 'Not Active';
    } else {
      finalStatus = 'Active';
    }

    return NextResponse.json({
      status: finalStatus,
      sourceStatus,
      name: ccbResult.name,
      licenseNumber: ccbResult.licenseNumber,
      jurisdiction,
      sourceJurisdiction: 'Oregon',
      jurisdictionMatch,
      expiration: 'See agency records',
      source: 'Oregon Construction Contractors Board',
    });
  } catch (error) {
    console.error('Oregon CCB lookup failed:', error);
    return NextResponse.json(
      {
        status: 'No Match',
        sourceStatus: 'Error',
        name: '—',
        licenseNumber,
        jurisdiction,
        sourceJurisdiction: '—',
        jurisdictionMatch: false,
        expiration: '—',
        source: 'Oregon CCB (lookup failed)',
      },
      { status: 502 }
    );
  }
}

function getSimulatedResult(licenseNumber: string, jurisdiction: string) {
  const records: Record<string, {
    name: string;
    sourceStatus: string;
    sourceJurisdiction: string;
    expiration: string;
    source: string;
  }> = {
    'ABC-12345': {
      name: 'Smith Roofing LLC',
      sourceStatus: 'Active',
      sourceJurisdiction: 'Florida',
      expiration: '2026-03-15',
      source: 'State Contractor Board (simulated)',
    },
    'XYZ-99999': {
      name: 'QuickFix Services',
      sourceStatus: 'Expired',
      sourceJurisdiction: 'Florida',
      expiration: '2023-11-01',
      source: 'State Contractor Board (simulated)',
    },
    'LIC-55555': {
      name: 'Reliable AC Pros',
      sourceStatus: 'Active',
      sourceJurisdiction: 'Texas',
      expiration: '2027-12-31',
      source: 'State Contractor Board (simulated)',
    },
    'SUS-77777': {
      name: 'Shady Repairs Inc',
      sourceStatus: 'Suspended',
      sourceJurisdiction: 'California',
      expiration: '2028-06-01',
      source: 'State Contractor Board (simulated)',
    },
  };

  const record = records[licenseNumber.toUpperCase()];

  if (!record) {
    return {
      status: 'No Match',
      sourceStatus: '—',
      name: '—',
      licenseNumber,
      jurisdiction,
      sourceJurisdiction: '—',
      jurisdictionMatch: false,
      expiration: '—',
      source: 'State Contractor Board (simulated)',
    };
  }

  const today = new Date();
  const expDate = new Date(record.expiration);
  const isExpired = expDate < today;

  const negativeStatuses = ['Suspended', 'Revoked', 'Expired', 'Inactive'];
  const isNegativeStatus = negativeStatuses.includes(record.sourceStatus);

  const userJurisdiction = jurisdiction.trim().toLowerCase();
  const sourceJurisdiction = record.sourceJurisdiction.trim().toLowerCase();
  const jurisdictionMatch = userJurisdiction === sourceJurisdiction;

  let finalStatus: string;
  if (isNegativeStatus) {
    finalStatus = 'Not Active';
  } else if (isExpired) {
    finalStatus = 'Not Active';
  } else if (!jurisdictionMatch) {
    finalStatus = 'Not Active';
  } else {
    finalStatus = 'Active';
  }

  return {
    status: finalStatus,
    sourceStatus: record.sourceStatus,
    name: record.name,
    licenseNumber: licenseNumber.toUpperCase(),
    jurisdiction,
    sourceJurisdiction: record.sourceJurisdiction,
    jurisdictionMatch,
    expiration: record.expiration,
    source: record.source,
  };
}
