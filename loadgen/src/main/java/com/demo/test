/**
 * Three-outcome resume prompt.
 * Returns 'resume' | 'fresh' | 'back'
 * 
 * 'back'   — user dismissed (×, backdrop, Escape) → navigate back, do nothing
 * 'resume' — user wants to continue the interrupted session
 * 'fresh'  — user wants to start a new session (abandons the old one)
 */
async function showResumePrompt({ exerciseName, setNumber, ageLabel }) {
  return new Promise((resolve) => {
    const content = document.createElement('div');
    content.className = 'dialog-content';
    content.innerHTML = `
      <p class="dialog-message">
        You were doing <strong>${escapeHtml(exerciseName)}</strong> 
        (set ${setNumber}) — paused ${escapeHtml(ageLabel)}.
      </p>

      <div class="dialog-actions" style="flex-direction: column; gap: 8px;">
        <button type="button" class="btn btn-primary" id="resume-btn" style="width: 100%;">
          Resume where I left off
        </button>
        <button type="button" class="btn btn-secondary" id="fresh-btn" style="width: 100%;">
          Start fresh
        </button>
      </div>
    `;

    let resolved = false;
    const finish = (decision) => {
      if (resolved) return;
      resolved = true;
      closeModal(modal);
      resolve(decision);
    };

    const modal = openModal({
      title: 'Resume session?',
      content,
      dismissable: true,
      onClose: (reason) => {
        // '×' button, backdrop click, Escape, popstate → go back
        if (!resolved) {
          resolved = true;
          resolve('back');
        }
      },
    });

    content.querySelector('#resume-btn').addEventListener('click', () => finish('resume'));
    content.querySelector('#fresh-btn').addEventListener('click', () => finish('fresh'));
  });
}
