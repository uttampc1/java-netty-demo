<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>YouTube iframe Wake Test</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, sans-serif; background:#111; color:#eee; padding:16px; padding-top: env(safe-area-inset-top,16px); }
    h1 { font-size:18px; margin-bottom:12px; }
    .yt-wrap { position:relative; width:100%; padding-bottom:56.25%; margin-bottom:16px; }
    .yt-wrap iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:0; border-radius:8px; }
    .timer { font-size:44px; font-weight:300; text-align:center; font-variant-numeric:tabular-nums; margin:12px 0; }
    .status { text-align:center; padding:12px; border-radius:8px; background:#333; margin:12px 0; font-weight:700; }
    .log { background:#000; color:#6f6; padding:12px; border-radius:8px; font-family:monospace; font-size:11px; max-height:160px; overflow-y:auto; white-space:pre-wrap; margin-top:12px; }
    .hint { font-size:12px; color:#999; line-height:1.5; margin-top:8px; }
  </style>
</head>
<body>
  <h1>🎬 YouTube iframe Test</h1>

  <div class="yt-wrap">
    <!-- autoplay + playsinline; mute=0 so audio route is active -->
    <iframe id="yt"
      src="https://www.youtube.com/embed/RiwCzRnaTkg?autoplay=1&playsinline=1&mute=0&controls=1&loop=1&playlist=RiwCzRnaTkg"
      allow="autoplay; encrypted-media"
      allowfullscreen>
    </iframe>
  </div>

  <div class="status" id="status">iframe loaded — press play in the video if not autoplaying</div>
  <div class="timer" id="timer">00:00</div>

  <div class="hint">
    1. If the video doesn't autoplay, tap play inside it.<br>
    2. Keep volume low but NOT muted (no mute symbol).<br>
    3. Pocket the phone, wait past auto-lock.<br>
    4. Screen stays on?
  </div>

  <div class="log" id="log">Ready…</div>

  <script>
    const logEl = document.getElementById('log');
    const timerEl = document.getElementById('timer');
    let lastVisible = Date.now();
    let start = Date.now();

    function log(m){ const t=new Date().toLocaleTimeString(); logEl.textContent=`[${t}] ${m}\n`+logEl.textContent; }

    setInterval(() => {
      const e = Math.floor((Date.now()-start)/1000);
      timerEl.textContent = `${String(Math.floor(e/60)).padStart(2,'0')}:${String(e%60).padStart(2,'0')}`;
    }, 500);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) log('📵 Page hidden (screen locked)');
      else { const h=Math.floor((Date.now()-lastVisible)/1000); log(`📱 Visible (hidden ~${h}s)`); }
      lastVisible = Date.now();
    });

    log(`UA: ${navigator.userAgent.slice(0,60)}...`);
    log('YouTube iframe should autoplay. If not, tap play.');
  </script>
</body>
</html>
