// src/utils/routineDuration.js
/**
 * HoldOn — Routine Duration Calculator
 * 
 * Pure helpers for calculating and formatting expected workout duration.
 * Used by the education dialog to show users how long a routine will take.
 */

const DEFAULT_PREP_DURATION = 3;

/**
 * Calculates the total expected duration of a routine in seconds.
 * Includes prep + all work phases + all rest phases.
 * 
 * @param {Object} routine - Routine object with exercises array
 * @param {number} [prepDuration=3] - Prep countdown duration
 * @returns {number} Total seconds
 */
export function calculateRoutineDuration(routine, prepDuration = DEFAULT_PREP_DURATION) {
  if (!routine || !Array.isArray(routine.exercises) || routine.exercises.length === 0) {
    return 0;
  }
  
  let total = prepDuration;  // initial prep countdown
  
  routine.exercises.forEach((exercise) => {
    const sets = Math.max(1, exercise.sets || 1);
    const workDuration = Math.max(0, exercise.workDuration || 0);
    const restBetweenSets = Math.max(0, exercise.restBetweenSets || 0);
    
    // All work phases for this exercise
    total += workDuration * sets;
    
    // Rests between sets (one fewer rest than sets — no rest after final set)
    if (sets > 1) {
      total += restBetweenSets * (sets - 1);
    }
  });
  
  // Rests between exercises (one fewer rest than exercises — no rest after final exercise)
  const restBetweenExercises = Math.max(0, routine.restBetweenExercises || 0);
  if (routine.exercises.length > 1) {
    total += restBetweenExercises * (routine.exercises.length - 1);
  }
  
  return total;
}

/**
 * Formats a duration in seconds to a human-friendly string.
 * Examples:
 *   45    → "45 seconds"
 *   60    → "1 minute"
 *   90    → "1 minute 30 seconds"
 *   600   → "10 minutes"
 *   863   → "14 minutes 23 seconds"
 *   3600  → "1 hour"
 *   3720  → "1 hour 2 minutes"
 * 
 * @param {number} seconds 
 * @returns {string}
 */
export function formatDuration(seconds) {
  if (!seconds || seconds < 0) return '0 seconds';
  
  seconds = Math.round(seconds);
  
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;
  
  const parts = [];
  
  if (hours > 0) {
    parts.push(`${hours} hour${hours === 1 ? '' : 's'}`);
  }
  
  if (minutes > 0) {
    parts.push(`${minutes} minute${minutes === 1 ? '' : 's'}`);
  }
  
  // Only show seconds if total < 1 hour AND there are nonzero seconds
  // Avoids awkward "1 hour 2 minutes 15 seconds"
  if (hours === 0 && secs > 0) {
    parts.push(`${secs} second${secs === 1 ? '' : 's'}`);
  }
  
  return parts.join(' ') || '0 seconds';
}

/**
 * Returns a compact form for tight UI spaces.
 * Examples:
 *   45    → "45s"
 *   60    → "1m"
 *   90    → "1m 30s"
 *   3720  → "1h 2m"
 * 
 * @param {number} seconds 
 * @returns {string}
 */
export function formatDurationCompact(seconds) {
  if (!seconds || seconds < 0) return '0s';
  
  seconds = Math.round(seconds);
  
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;
  
  const parts = [];
  
  if (hours > 0) parts.push(`${hours}h`);
  if (minutes > 0) parts.push(`${minutes}m`);
  if (hours === 0 && secs > 0) parts.push(`${secs}s`);
  
  return parts.join(' ') || '0s';
}
