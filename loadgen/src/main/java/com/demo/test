function showIOSExportFallback(jsonString, filename) {
  const content = document.createElement('div');
  content.className = 'ios-export-fallback';
  content.innerHTML = `
    <p class="muted ios-export-intro">
      Your browser doesn't support automatic downloads on iOS.
      Use one of these options to save your backup:
    </p>
    
    <div class="ios-export-option">
      <h4>Option 1: Copy to Clipboard</h4>
      <p class="muted">Tap the button to copy. If it fails, use Option 2 below.</p>
      <button type="button" class="btn btn-primary" id="copy-btn">
        📋 Copy Backup Data
      </button>
    </div>
    
    <div class="ios-export-option" id="manual-copy-section" hidden>
      <h4>Option 2: Copy Manually</h4>
      <p class="muted">Tap into the box, Select All, then Copy.</p>
      <textarea
        class="ios-export-textarea"
        id="manual-copy-textarea"
        readonly
        rows="6"
      >${escapeHtml(jsonString)}</textarea>
    </div>
    
    <div class="ios-export-option">
      <h4>Option 3: Use Safari</h4>
      <p class="muted">Open this app in Safari for full download support.</p>
    </div>
    
    <div class="ios-export-option">
      <h4>Filename suggestion</h4>
      <p class="ios-export-filename"><code>${escapeHtml(filename)}</code></p>
    </div>
  `;
  
  const modal = openModal({
    title: 'Export Data',
    content,
  });
  
  const copyBtn = content.querySelector('#copy-btn');
  const manualSection = content.querySelector('#manual-copy-section');
  const manualTextarea = content.querySelector('#manual-copy-textarea');
  
  copyBtn.addEventListener('click', async () => {
    let copied = false;
    
    // Strategy 1: Modern Clipboard API
    try {
      if (typeof navigator !== 'undefined' 
          && navigator.clipboard 
          && typeof navigator.clipboard.writeText === 'function') {
        await navigator.clipboard.writeText(jsonString);
        copied = true;
      }
    } catch (err) {
      console.warn('[Data] Clipboard API failed:', err);
    }
    
    // Strategy 2: Legacy execCommand fallback
    if (!copied) {
      try {
        const tempTextarea = document.createElement('textarea');
        tempTextarea.value = jsonString;
        tempTextarea.style.position = 'fixed';
        tempTextarea.style.top = '0';
        tempTextarea.style.left = '0';
        tempTextarea.style.opacity = '0';
        document.body.appendChild(tempTextarea);
        tempTextarea.focus();
        tempTextarea.select();
        copied = document.execCommand('copy');
        document.body.removeChild(tempTextarea);
      } catch (err) {
        console.warn('[Data] execCommand fallback failed:', err);
      }
    }
    
    if (copied) {
      copyBtn.textContent = '✅ Copied!';
      copyBtn.disabled = true;
      setTimeout(() => closeModal(modal), 1500);
    } else {
      // Both strategies failed — show manual copy textarea
      copyBtn.textContent = '⚠️ Use Option 2 below';
      copyBtn.disabled = true;
      manualSection.hidden = false;
      
      // Auto-select the textarea content for easier manual copy
      setTimeout(() => {
        manualTextarea.focus();
        manualTextarea.select();
      }, 100);
    }
  });
}

