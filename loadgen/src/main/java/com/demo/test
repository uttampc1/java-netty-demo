// src/views/routineEdit.js
/**
 * HoldOn — Routine Edit View
 * 
 * Unified form for creating a new routine or editing an existing one.
 * Route patterns:
 *   #/new          → create mode (no routineId)
 *   #/edit/:id     → edit mode (routineId provided)
 * 
 * Step 1.4.E.1 — Skeleton only (no exercise editor yet).
 */

import { getRoutine, createRoutine, updateRoutine } from '../db/store.js';
import { router } from '../utils/router.js';

/**
 * Renders the create/edit form.
 * @param {HTMLElement} container
 * @param {string|null} routineId - null for create mode
 */
export async function renderRoutineEdit(container, routineId = null) {
  const isEditMode = !!routineId;
  let routine;
  
  if (isEditMode) {
    routine = await getRoutine(routineId);
    if (!routine) {
      container.innerHTML = `
        <main class="container">
          <header class="screen-header">
            <button class="btn-link" id="back-btn">← Back</button>
            <h2>Not Found</h2>
            <div class="header-spacer"></div>
          </header>
          <section class="status-card">
            <p>This routine doesn't exist.</p>
          </section>
        </main>
      `;
      container.querySelector('#back-btn').addEventListener('click', () => router.navigate('/'));
      return;
    }
  } else {
    // Create mode — start with a blank routine in memory (not saved yet)
    routine = {
      title: '',
      description: '',
      restBetweenExercises: 15,
      exercises: [],
      useGlobalCues: true,
      cueType: 'beep',
      countdownAnnounce: true,
      tags: [],
      metadata: {},
    };
  }

  // Local working copy — changes are only persisted on Save
  const draft = { ...routine };

  container.innerHTML = `
    <main class="container">
      <header class="screen-header">
        <button class="btn-link" id="cancel-btn">Cancel</button>
        <h2>${isEditMode ? 'Edit Routine' : 'New Routine'}</h2>
        <button class="btn-link btn-link-bold" id="save-btn">Save</button>
      </header>

      <form class="routine-form" id="routine-form" autocomplete="off">
        <div class="form-group">
          <label for="field-title">Title</label>
          <input
            type="text"
            id="field-title"
            name="title"
            placeholder="e.g., Lower Back Strengthening"
            value="${escapeHtml(draft.title)}"
            maxlength="100"
            required
          />
        </div>

        <div class="form-group">
          <label for="field-description">Description <span class="form-label-hint">(optional)</span></label>
          <textarea
            id="field-description"
            name="description"
            placeholder="e.g., A gentle routine for daily practice."
            rows="3"
            maxlength="500"
          >${escapeHtml(draft.description)}</textarea>
        </div>

        <div class="form-group">
          <label for="field-rest">
            Rest between exercises
            <span class="form-label-hint">(seconds)</span>
          </label>
          <div class="number-input-wrapper">
            <input
              type="number"
              id="field-rest"
              name="restBetweenExercises"
              min="0"
              max="120"
              step="1"
              value="${draft.restBetweenExercises}"
            />
            <span class="number-input-suffix">sec</span>
          </div>
          <p class="form-hint">Pause time when moving from one exercise to the next.</p>
        </div>

        <div class="form-section-divider"></div>

        <div class="form-group">
          <h3 class="section-heading">Exercises</h3>
          <div class="placeholder-card">
            <p class="muted">Exercise editor coming in the next step (1.4.E.2).</p>
            <p class="muted" style="font-size: 13px;">Currently this routine has <strong>${draft.exercises.length}</strong> exercise${draft.exercises.length === 1 ? '' : 's'}.</p>
          </div>
        </div>
      </form>
    </main>
  `;

  // Wire up form handlers
  const form = container.querySelector('#routine-form');
  const titleInput = container.querySelector('#field-title');
  const descInput = container.querySelector('#field-description');
  const restInput = container.querySelector('#field-rest');
  const saveBtn = container.querySelector('#save-btn');
  const cancelBtn = container.querySelector('#cancel-btn');

  // Live-update draft as user types (no DB writes yet)
  titleInput.addEventListener('input', (e) => {
    draft.title = e.target.value;
  });
  descInput.addEventListener('input', (e) => {
    draft.description = e.target.value;
  });
  restInput.addEventListener('input', (e) => {
    const value = parseInt(e.target.value, 10);
    draft.restBetweenExercises = isNaN(value) ? 0 : Math.max(0, Math.min(120, value));
  });

  // Prevent form submission via Enter key (we have our own Save button)
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    handleSave();
  });

  // Cancel — just navigate back (no unsaved changes protection in v1)
  cancelBtn.addEventListener('click', () => {
    if (isEditMode) {
      router.navigate(`/routine/${routineId}`);
    } else {
      router.navigate('/');
    }
  });

  // Save handler
  async function handleSave() {
    // Validation: title is required
    const trimmedTitle = (draft.title || '').trim();
    if (!trimmedTitle) {
      alert('Please enter a title for your routine.');
      titleInput.focus();
      return;
    }
    draft.title = trimmedTitle;
    draft.description = (draft.description || '').trim();

    // Disable button to prevent double-click
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      let savedRoutine;
      if (isEditMode) {
        savedRoutine = await updateRoutine(draft);
        router.navigate(`/routine/${savedRoutine.id}`);
      } else {
        savedRoutine = await createRoutine(draft);
        router.navigate(`/routine/${savedRoutine.id}`);
      }
    } catch (err) {
      console.error('Failed to save routine:', err);
      alert('Failed to save: ' + err.message);
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save';
    }
  }

  saveBtn.addEventListener('click', handleSave);

  // Auto-focus title field in create mode
  if (!isEditMode) {
    setTimeout(() => titleInput.focus(), 50);
  }
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// style.css
/* === Step 1.4.E.1 — Routine Form === */

/* Form layout */
.routine-form {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-size: 15px;
  font-weight: 500;
  margin-bottom: 8px;
  color: var(--text);
}

.form-label-hint {
  font-weight: 400;
  color: var(--text-muted);
  font-size: 13px;
}

.form-hint {
  margin: 6px 0 0 0;
  font-size: 13px;
  color: var(--text-muted);
}

/* Inputs and textareas */
.form-group input[type="text"],
.form-group input[type="number"],
.form-group textarea {
  width: 100%;
  padding: 12px 14px;
  font-family: inherit;
  font-size: 16px;          /* 16px prevents iOS zoom on focus */
  color: var(--text);
  background-color: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  outline: none;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
  -webkit-appearance: none;
  appearance: none;
}

.form-group textarea {
  resize: vertical;
  min-height: 72px;
  font-family: inherit;
  line-height: 1.5;
}

.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.15);
}

@media (prefers-color-scheme: dark) {
  .form-group input:focus,
  .form-group textarea:focus {
    box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.25);
  }
}

/* Number input with suffix (e.g., "sec") */
.number-input-wrapper {
  position: relative;
  display: inline-block;
  width: 140px;
}

.number-input-wrapper input[type="number"] {
  padding-right: 44px;
  text-align: right;
  -moz-appearance: textfield;
}

.number-input-wrapper input[type="number"]::-webkit-outer-spin-button,
.number-input-wrapper input[type="number"]::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.number-input-suffix {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  font-size: 14px;
  pointer-events: none;
}

/* Section divider */
.form-section-divider {
  height: 1px;
  background-color: var(--border);
  margin: 8px 0 20px 0;
}

/* Bold link variant (for Save button in header) */
.btn-link-bold {
  font-weight: 600;
}

.btn-link:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  pointer-events: none;
}

/* Placeholder card (used in 1.4.E.1 for the "exercises coming soon" area) */
.placeholder-card {
  background-color: var(--bg-elevated);
  border: 1px dashed var(--border);
  border-radius: var(--radius);
  padding: 20px;
  text-align: center;
}

.placeholder-card p {
  margin: 6px 0;
}

// main.js
import { renderRoutineEdit } from './views/routineEdit.js';

