  height: 28px;
  border-radius: 50%;
  background-color: var(--accent);
  color: white;
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exercise-detail-main {
  flex: 1;
  min-width: 0;
}

.exercise-detail-name {
  margin: 0 0 4px 0;
  font-size: 16px;
  font-weight: 600;
}

.exercise-detail-desc {
  margin: 0 0 8px 0;
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.4;
}

.exercise-detail-meta {
  margin: 4px 0;
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
}

.video-link {
  display: inline-block;
  margin-top: 6px;
  color: var(--accent);
  font-size: 13px;
  font-weight: 500;
  text-decoration: none;
}

.video-link:hover {
  text-decoration: underline;
}

/* Primary & Danger Actions */
.primary-action {
  margin: 32px 0 16px 0;
}

.btn-large {
  width: 100%;
  padding: 16px 24px;
  font-size: 17px;
  font-weight: 600;
  border-radius: var(--radius);
}

.btn-large:disabled {
  background-color: var(--text-muted);
  opacity: 0.4;
  cursor: not-allowed;
}

.danger-action {
  margin-top: 8px;
  display: flex;
  justify-content: center;
}

.btn-danger {
  background: none;
  color: #ff3b30;
  padding: 12px 20px;
  font-size: 15px;
  font-weight: 400;
}

.btn-danger:hover {
  background-color: rgba(255, 59, 48, 0.08);
}

.btn-danger:active {
  background-color: rgba(255, 59, 48, 0.15);
}

@media (prefers-color-scheme: dark) {
  .btn-danger {
    color: #ff453a;
  }
  .btn-danger:hover {
    background-color: rgba(255, 69, 58, 0.12);
  }
}

