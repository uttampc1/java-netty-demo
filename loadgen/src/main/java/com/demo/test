// Styles
/* === Phase 2 / Step 2.1 — Session Player === */

.player {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  background-color: var(--bg);
  color: var(--text);
  z-index: 1000;
  padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
  overflow: hidden;
}

/* Top: routine title */
.player-top {
  flex-shrink: 0;
  padding: 20px 20px 0;
  text-align: center;
}

.player-routine-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* Main: exercise + timer */
.player-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 20px;
  min-height: 0;
  text-align: center;
}

.player-exercise-name {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
  line-height: 1.2;
  max-width: 100%;
  word-wrap: break-word;
}

.player-set-counter {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-muted);
  font-variant-numeric: tabular-nums;
}

.player-phase-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  border-radius: 16px;
  background-color: var(--bg-elevated);
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text);
  margin-top: 4px;
}

.player-phase-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: var(--text-muted);
  display: inline-block;
}

/* Phase-specific colors */
.player[data-phase="prep"] .player-phase-dot {
  background-color: #ff9500;
  animation: pulse 1.2s ease-in-out infinite;
}
.player[data-phase="work"] .player-phase-dot {
  background-color: #007aff;
  animation: pulse 1.2s ease-in-out infinite;
}
.player[data-phase="rest-set"] .player-phase-dot,
.player[data-phase="rest-exercise"] .player-phase-dot {
  background-color: #34c759;
}
.player[data-phase="complete"] .player-phase-dot {
  background-color: #ffd700;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.85); }
}

/* The big timer display */
.player-timer {
  font-size: 96px;
  font-weight: 200;
  line-height: 1;
  letter-spacing: -0.04em;
  font-variant-numeric: tabular-nums;
  color: var(--text);
  margin: 12px 0;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
}

/* Larger timer on bigger screens */
@media (min-height: 700px) {
  .player-timer {
    font-size: 128px;
  }
}

@media (min-height: 900px) {
  .player-timer {
    font-size: 160px;
  }
}

.player-next {
  font-size: 14px;
  color: var(--text-muted);
  margin-top: 8px;
  max-width: 100%;
  word-wrap: break-word;
}

/* Controls at bottom */
.player-controls {
  flex-shrink: 0;
  display: flex;
  gap: 8px;
  padding: 16px 20px 24px;
  justify-content: space-around;
}

.player-control-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  background: none;
  border: none;
  padding: 12px 8px;
  border-radius: var(--radius);
  color: var(--text);
  cursor: pointer;
  font-family: inherit;
  transition: background-color 0.15s ease, transform 0.05s ease;
  -webkit-tap-highlight-color: transparent;
  min-height: 64px;
}

.player-control-btn:hover {
  background-color: var(--bg-elevated);
}

.player-control-btn:active {
  transform: scale(0.96);
  background-color: rgba(0, 0, 0, 0.08);
}

@media (prefers-color-scheme: dark) {
  .player-control-btn:active {
    background-color: rgba(255, 255, 255, 0.1);
  }
}

.player-control-icon {
  font-size: 22px;
  line-height: 1;
}

.player-control-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
}

.player-exit-btn .player-control-icon,
.player-exit-btn .player-control-label {
  color: #ff3b30;
}

@media (prefers-color-scheme: dark) {
  .player-exit-btn .player-control-icon,
  .player-exit-btn .player-control-label {
    color: #ff453a;
  }
}

/* Subtle background tinting for active phases (very subtle) */
.player[data-phase="work"] {
  background-color: var(--bg);
}

.player[data-phase="rest-set"],
.player[data-phase="rest-exercise"] {
  background-color: var(--bg);
}
