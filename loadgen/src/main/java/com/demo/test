   const exercisesHtml = draft.exercises.map((ex, idx) => `
      <div class="exercise-row" data-exercise-id="${escapeHtml(ex.id)}">
        <div class="exercise-drag-handle" aria-label="Drag to reorder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
            <line x1="4" y1="8" x2="20" y2="8"/>
            <line x1="4" y1="16" x2="20" y2="16"/>
          </svg>
        </div>
        <div class="exercise-row-main">
          <div class="exercise-row-content">
            <div class="exercise-row-name">${escapeHtml(ex.name)}</div>
            <div class="exercise-row-meta">
              ${ex.workDuration}s × ${ex.sets} set${ex.sets === 1 ? '' : 's'}${ex.sets > 1 && ex.restBetweenSets > 0 ? ` · ${ex.restBetweenSets}s rest` : ''}
            </div>
          </div>
        </div>
        <div class="exercise-row-actions">
          <button type="button" class="btn-icon-only" data-action="edit-exercise" data-exercise-id="${escapeHtml(ex.id)}" aria-label="Edit">
            ✎
          </button>
          <button type="button" class="btn-icon-only btn-icon-danger" data-action="remove-exercise" data-exercise-id="${escapeHtml(ex.id)}" aria-label="Remove">
            ✕
          </button>
        </div>
      </div>
    `).join('');

// add just before ...
    // Enable drag-to-reorder
    const listEl = container.querySelector('#exercise-list');
    if (listEl && draft.exercises.length > 1) {
      Sortable.create(listEl, {
        handle: '.exercise-drag-handle',
        animation: 150,
        ghostClass: 'exercise-row-ghost',
        chosenClass: 'exercise-row-chosen',
        dragClass: 'exercise-row-drag',
        forceFallback: true,  // consistent behavior across browsers (especially iOS)
        fallbackTolerance: 5,
        onEnd: (evt) => {
          // Reorder the draft.exercises array to match the new DOM order
          if (evt.oldIndex === evt.newIndex) return;
          
          const [moved] = draft.exercises.splice(evt.oldIndex, 1);
          draft.exercises.splice(evt.newIndex, 0, moved);
          
          console.log('[Reorder] Moved from', evt.oldIndex, 'to', evt.newIndex);
        },
      });
    }
  }

/* === Step 1.4.G.3 — Drag-to-Reorder === */

.exercise-row {
  position: relative;
  /* existing styles preserved */
}

.exercise-drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  flex-shrink: 0;
  color: var(--text-muted);
  cursor: grab;
  touch-action: none;  /* prevents touch scroll interference */
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  -webkit-user-select: none;
  transition: color 0.15s ease;
}

.exercise-drag-handle:hover {
  color: var(--text);
}

.exercise-drag-handle:active {
  cursor: grabbing;
}

/* While dragging — the original spot (shown as a "ghost") */
.exercise-row-ghost {
  opacity: 0.3;
  background-color: var(--bg-elevated);
}

/* The row that's currently being dragged */
.exercise-row-chosen {
  /* SortableJS adds this when drag starts but before move */
}

/* The floating clone that follows the pointer */
.exercise-row-drag {
  opacity: 0.95;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  transform: scale(1.02);
  background-color: var(--bg);
  border-radius: var(--radius-sm);
}

@media (prefers-color-scheme: dark) {
  .exercise-row-drag {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    background-color: var(--bg-elevated);
  }
}

/* Ensure the exercise row layout includes the handle */
.exercise-row {
  display: flex;
  align-items: center;
  /* preserve any existing properties */
}


