/**
 * HoldOn — Session History Modal (Phase 2 placeholder)
 * 
 * Simple read-only list of sessions for a routine.
 * Phase 3 will replace with a full history view.
 */

import { openModal, closeModal } from './modal.js';
import { getSessionsByRoutine } from '../db/store.js';

export async function openHistoryModal(routine) {
  let sessions = [];
  try {
    sessions = await getSessionsByRoutine(routine.id);
  } catch (err) {
    console.warn('[History] Could not load sessions:', err);
  }
  
  // Filter out 'in-progress' orphans (e.g., from browser back during workout)
  sessions = sessions.filter((s) => s.status === 'complete' || s.status === 'incomplete');
  
  const content = document.createElement('div');
  content.className = 'history-modal';
  
  if (sessions.length === 0) {
    content.innerHTML = `
      <div class="history-empty">
        <div class="history-empty-icon">📭</div>
        <div class="history-empty-text">No sessions yet</div>
        <div class="history-empty-hint">Complete a workout to see it here.</div>
      </div>
    `;
  } else {
    const totalElapsed = sessions.reduce((sum, s) => sum + (s.totalElapsed || 0), 0);
    const completeCount = sessions.filter((s) => s.status === 'complete').length;
    
    content.innerHTML = `
      <div class="history-list">
        ${sessions.map(renderSessionRow).join('')}
      </div>
      
      <div class="history-footer">
        ${sessions.length} session${sessions.length === 1 ? '' : 's'}
        (${completeCount} complete) · Total: ${formatDuration(totalElapsed)}
      </div>
    `;
  }
  
  openModal({
    title: `History · ${routine.title}`,
    content,
  });
}

function renderSessionRow(session) {
  const isComplete = session.status === 'complete';
  const icon = isComplete ? '✓' : '⊘';
  const iconClass = isComplete ? 'history-row-icon-complete' : 'history-row-icon-incomplete';
  const statusLabel = isComplete ? '' : ' (partial)';
  
  const date = formatDate(session.startedAt);
  const duration = formatDuration(session.totalElapsed || 0);
  const setsInfo = session.setsCompleted && session.totalSets
    ? `${session.setsCompleted}/${session.totalSets} sets`
    : '';
  
  return `
    <div class="history-row">
      <div class="history-row-icon ${iconClass}">${icon}</div>
      <div class="history-row-main">
        <div class="history-row-date">${escapeHtml(date)}${escapeHtml(statusLabel)}</div>
        <div class="history-row-meta">
          ${escapeHtml(duration)}${setsInfo ? ` · ${escapeHtml(setsInfo)}` : ''}
        </div>
      </div>
    </div>
  `;
}

function formatDate(timestamp) {
  if (!timestamp) return 'Unknown date';
  const d = new Date(timestamp);
  const now = new Date();
  
  // Today
  if (d.toDateString() === now.toDateString()) {
    return `Today, ${d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' })}`;
  }
  
  // Yesterday
  const yesterday = new Date(now);
  yesterday.setDate(now.getDate() - 1);
  if (d.toDateString() === yesterday.toDateString()) {
    return `Yesterday, ${d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' })}`;
  }
  
  // This week (within 7 days)
  const diffDays = Math.floor((now - d) / (1000 * 60 * 60 * 24));
  if (diffDays < 7) {
    return d.toLocaleDateString(undefined, { weekday: 'long', hour: 'numeric', minute: '2-digit' });
  }
  
  // Older
  return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
}

function formatDuration(seconds) {
  if (!seconds || seconds < 0) return '0s';
  const mins = Math.floor(seconds / 60);
  const secs = Math.floor(seconds % 60);
  if (mins === 0) return `${secs}s`;
  if (secs === 0) return `${mins}m`;
  return `${mins}m ${secs}s`;
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// Style
/* === Phase 2 / Step 2.6.5 — History Modal (placeholder) === */

.routine-actions-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.routine-actions-group .btn {
  width: 100%;
  justify-content: center;
}

/* History modal */
.history-modal {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-empty {
  text-align: center;
  padding: 32px 16px;
}

.history-empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
  opacity: 0.6;
}

.history-empty-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.history-empty-hint {
  font-size: 13px;
  color: var(--text-muted);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
  max-height: 400px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background-color: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
}

.history-row-icon {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 16px;
  font-weight: 700;
}

.history-row-icon-complete {
  background-color: rgba(52, 199, 89, 0.15);
  color: #34c759;
}

.history-row-icon-incomplete {
  background-color: rgba(255, 149, 0, 0.15);
  color: #ff9500;
}

@media (prefers-color-scheme: dark) {
  .history-row-icon-complete {
    background-color: rgba(48, 209, 88, 0.2);
    color: #30d158;
  }
  .history-row-icon-incomplete {
    background-color: rgba(255, 159, 10, 0.2);
    color: #ff9f0a;
  }
}

.history-row-main {
  flex: 1;
  min-width: 0;
}

.history-row-date {
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 2px;
}

.history-row-meta {
  font-size: 12px;
  color: var(--text-muted);
  font-variant-numeric: tabular-nums;
}

.history-footer {
  padding: 12px;
  text-align: center;
  font-size: 12px;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  margin-top: 4px;
}
