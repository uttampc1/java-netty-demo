/**
 * Returns all sessions, sorted by startedAt descending (newest first).
 */
export async function getAllSessions() {
  const db = await getDB();
  const sessions = await db.getAll(STORE_SESSIONS);
  return sessions.sort((a, b) => (b.startedAt || 0) - (a.startedAt || 0));
}

/**
 * Returns a single session by id, or null if not found.
 */
export async function getSession(id) {
  const db = await getDB();
  const session = await db.get(STORE_SESSIONS, id);
  return session || null;
}

/**
 * Returns sessions filtered by status ('complete' | 'incomplete' | 'in-progress').
 */
export async function getSessionsByStatus(status) {
  const all = await getAllSessions();
  return all.filter((s) => s.status === status);
}

/**
 * Returns sessions for a specific routine.
 */
export async function getSessionsByRoutine(routineId) {
  const all = await getAllSessions();
  return all.filter((s) => s.routineId === routineId);
}
