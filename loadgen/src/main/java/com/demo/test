async function handleImportFile(e) {
  const file = e.target.files && e.target.files[0];
  e.target.value = '';  // reset input so same file can be picked again later
  
  if (!file) return;
  
  try {
    const jsonString = await readFileAsText(file);
    processImportData(jsonString);
  } catch (err) {
    console.error('[Import] Failed to read file:', err);
    alert('Failed to read file: ' + err.message);
  }
}

function readFileAsText(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = () => reject(new Error('File could not be read.'));
    reader.readAsText(file);
  });
}

/**
 * Validates JSON, then shows confirmation modal (1.4.F.3.B.2.B).
 * For 1.4.F.3.B.2.A: just shows an alert with the summary.
 */
function processImportData(jsonString) {
  const result = parseAndValidateBackup(jsonString);
  
  if (!result.valid) {
    alert('Import failed:\n\n' + result.error);
    return;
  }
  
  // For 1.4.F.3.B.2.A: show summary as alert (confirmation modal in next sub-chunk)
  const s = result.summary;
  const exportedDate = s.exportedAt 
    ? new Date(s.exportedAt).toLocaleDateString()
    : 'unknown date';
  
  const summaryText = 
    `Valid HoldOn backup (version ${s.version}, exported ${exportedDate})\n\n` +
    `Contents:\n` +
    `  • ${s.routineCount} routine${s.routineCount === 1 ? '' : 's'}\n` +
    `  • ${s.customActivityCount} custom ${s.customActivityCount === 1 ? 'activity' : 'activities'}\n` +
    `  • ${s.seededActivityCount} seeded ${s.seededActivityCount === 1 ? 'activity' : 'activities'} (will be skipped)\n` +
    `  • ${s.sessionCount} session${s.sessionCount === 1 ? '' : 's'}\n\n` +
    `Replace/Merge confirmation modal coming in Step 1.4.F.3.B.2.B.`;
  
  alert(summaryText);
  console.log('[Import] Validated backup:', result.data);
}

// wireDataSection

function showIOSImportFallback() {
  const content = document.createElement('div');
  content.className = 'ios-import-fallback';
  content.innerHTML = `
    <p class="muted ios-export-intro">
      Your browser doesn't support file picking on iOS.
      Paste your backup JSON below to import:
    </p>
    
    <div class="ios-export-option">
      <h4>Paste backup data</h4>
      <textarea
        class="ios-export-textarea"
        id="paste-textarea"
        placeholder="Paste your HoldOn backup JSON here..."
        rows="8"
      ></textarea>
    </div>
    
    <div class="editor-actions">
      <button type="button" class="btn btn-secondary" id="paste-cancel">Cancel</button>
      <button type="button" class="btn btn-primary" id="paste-validate" disabled>Validate</button>
    </div>
    
    <div class="ios-export-option">
      <h4>Alternative: Use Safari</h4>
      <p class="muted">Open this app in Safari for a standard file picker.</p>
    </div>
  `;
  
  const modal = openModal({
    title: 'Import Data',
    content,
  });
  
  const textarea = content.querySelector('#paste-textarea');
  const validateBtn = content.querySelector('#paste-validate');
  const cancelBtn = content.querySelector('#paste-cancel');
  
  // Enable validate button when textarea has content
  textarea.addEventListener('input', () => {
    validateBtn.disabled = textarea.value.trim().length === 0;
  });
  
  cancelBtn.addEventListener('click', () => closeModal(modal));
  
  validateBtn.addEventListener('click', () => {
    const jsonString = textarea.value.trim();
    if (!jsonString) return;
    closeModal(modal);
    setTimeout(() => processImportData(jsonString), 150);
  });
  
  setTimeout(() => textarea.focus(), 100);
}

