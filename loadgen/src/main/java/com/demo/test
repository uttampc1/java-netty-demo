// ============================================================
// EXPORT
// ============================================================

async function handleExport() {
  try {
    const data = await exportAllData();
    const date = new Date().toISOString().split('T')[0];
    const filename = `holdon-backup-${date}.json`;
    const jsonString = JSON.stringify(data, null, 2);
    
    // Try Web Share API first (works great on iOS Safari + Android)
    if (canShareFiles()) {
      const file = new File([jsonString], filename, { type: 'application/json' });
      if (navigator.canShare({ files: [file] })) {
        try {
          await navigator.share({
            files: [file],
            title: 'HoldOn Backup',
          });
          console.log('[Data] Shared via Web Share API');
          return;
        } catch (shareErr) {
          // User cancelled share, OR share failed — fall through to download
          if (shareErr.name !== 'AbortError') {
            console.warn('[Data] Share failed, falling back to download:', shareErr);
          } else {
            return;  // User cancelled, don't auto-fallback
          }
        }
      }
    }
    
    // iOS non-Safari: download won't work, show copy/share modal
    if (isIOSNonSafari()) {
      showIOSExportFallback(jsonString, filename);
      return;
    }
    
    // Standard download (desktop + iOS Safari + Android)
    triggerDownload(jsonString, filename);
    console.log('[Data] Exported:', filename);
  } catch (err) {
    console.error('[Data] Export failed:', err);
    alert('Export failed: ' + err.message);
  }
}

function triggerDownload(jsonString, filename) {
  const blob = new Blob([jsonString], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function showIOSExportFallback(jsonString, filename) {
  const content = document.createElement('div');
  content.className = 'ios-export-fallback';
  content.innerHTML = `
    <p class="muted ios-export-intro">
      Your browser doesn't support automatic downloads on iOS.
      Use one of these options to save your backup:
    </p>
    
    <div class="ios-export-option">
      <h4>Option 1: Copy to Clipboard</h4>
      <p class="muted">Then paste into Notes, Files, or any text editor.</p>
      <button type="button" class="btn btn-primary" id="copy-btn">
        📋 Copy Backup Data
      </button>
    </div>
    
    <div class="ios-export-option">
      <h4>Option 2: Use Safari</h4>
      <p class="muted">Open this app in Safari for full download support.</p>
    </div>
    
    <div class="ios-export-option">
      <h4>Filename suggestion</h4>
      <p class="ios-export-filename"><code>${escapeHtml(filename)}</code></p>
    </div>
  `;
  
  const modal = openModal({
    title: 'Export Data',
    content,
  });
  
  // Copy to clipboard handler
  const copyBtn = content.querySelector('#copy-btn');
  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(jsonString);
      copyBtn.textContent = '✅ Copied!';
      copyBtn.disabled = true;
      setTimeout(() => {
        closeModal(modal);
      }, 1500);
    } catch (err) {
      console.error('[Data] Clipboard write failed:', err);
      // Fallback for browsers without clipboard API
      copyBtn.textContent = '⚠️ Copy failed — see console';
      console.log('=== HOLDON BACKUP (copy manually) ===');
      console.log(jsonString);
    }
  });
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// styles
/* === iOS Export Fallback Modal === */

.ios-export-fallback {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.ios-export-intro {
  margin: 0;
  font-size: 14px;
  line-height: 1.5;
}

.ios-export-option {
  background-color: var(--bg-elevated);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  border: 1px solid var(--border);
}

.ios-export-option h4 {
  margin: 0 0 4px 0;
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}

.ios-export-option p {
  margin: 0 0 10px 0;
  font-size: 13px;
  line-height: 1.4;
}

.ios-export-option p:last-child {
  margin-bottom: 0;
}

.ios-export-option button {
  width: 100%;
  justify-content: center;
}

.ios-export-filename code {
  display: inline-block;
  background-color: rgba(0, 0, 0, 0.06);
  padding: 4px 8px;
  border-radius: 4px;
  font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
  font-size: 13px;
}

@media (prefers-color-scheme: dark) {
  .ios-export-filename code {
    background-color: rgba(255, 255, 255, 0.1);
  }
}
