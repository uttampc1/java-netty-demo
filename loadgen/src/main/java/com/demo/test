<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inner Player</title>
  <style>
    * { margin: 0; padding: 0; }
    html, body { width: 100%; height: 100%; background: #000; overflow: hidden; }
    video { width: 100%; height: 100%; object-fit: cover; display: block; }
  </style>
</head>
<body>
  <video id="v" loop playsinline autoplay></video>
  <script>
    const v = document.getElementById('v');
    v.src = 'keepawake.mp4';
    v.muted = false;
    v.volume = 1.0;
    v.loop = true;

    // Try autoplay; if blocked, the parent will trigger play
    v.play().catch(e => {
      document.body.addEventListener('click', () => v.play(), { once: true });
    });

    // Setup Media Session inside the iframe too
    if ('mediaSession' in navigator) {
      navigator.mediaSession.metadata = new MediaMetadata({
        title: 'HoldOn Workout',
        artist: 'Keep Awake',
        album: 'Exercise'
      });
      navigator.mediaSession.playbackState = 'playing';
    }

    // Expose play control to parent
    window.startVideo = () => v.play();
    window.stopVideo = () => v.pause();
  </script>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <title>iframe Self-Video Wake Test</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, sans-serif; background:#111; color:#eee; padding:16px; padding-top: env(safe-area-inset-top,16px); }
    h1 { font-size:19px; margin-bottom:12px; }

    .frame-wrap { width:100%; height:40vh; margin-bottom:14px; border-radius:8px; overflow:hidden; background:#000; }
    .frame-wrap.tiny { width:60px; height:60px; }
    .frame-wrap.hidden { width:2px; height:2px; opacity:0.01; }
    iframe { width:100%; height:100%; border:0; display:block; }

    .status { text-align:center; padding:14px; border-radius:8px; background:#333; margin:10px 0; font-weight:700; }
    .status.playing { background:#1b5e20; color:#a5d6a7; }
    .timer { font-size:42px; font-weight:300; text-align:center; font-variant-numeric:tabular-nums; margin:10px 0; }

    button { display:block; width:100%; padding:15px; font-size:16px; font-weight:700; border:none; border-radius:10px; cursor:pointer; margin-bottom:8px; -webkit-tap-highlight-color:transparent; }
    .btn-go { background:#34c759; color:white; }
    .btn-stop { background:#ff3b30; color:white; }
    .btn-size { background:#555; color:white; }

    .log { background:#000; color:#6f6; padding:12px; border-radius:8px; font-family:monospace; font-size:11px; max-height:160px; overflow-y:auto; white-space:pre-wrap; margin-top:10px; }
    .hint { font-size:12px; color:#999; line-height:1.5; margin-top:8px; }
  </style>
</head>
<body>
  <h1>🎬 Our Video in iframe</h1>

  <!-- iframe plays OUR keepawake.mp4 (not YouTube) -->
  <div class="frame-wrap" id="frame-wrap">
    <iframe id="frame" src="player.html"></iframe>
  </div>

  <div class="status" id="status">Tap Start (then tap the video if it doesn't autoplay)</div>
  <div class="timer" id="timer">00:00</div>

  <button class="btn-go" id="go-btn">▶ Start</button>
  <button class="btn-stop" id="stop-btn" style="display:none;">⏹ Stop</button>
  <button class="btn-size" id="size-btn">📐 Size: 40vh</button>

  <div class="hint">
    Tests if OUR keepawake.mp4 inside an iframe keeps the screen on (like YouTube did).
    Keep volume down but NOT muted. Pocket phone, wait past auto-lock.
  </div>

  <div class="log" id="log">Ready…</div>

  <script>
    const frame = document.getElementById('frame');
    const frameWrap = document.getElementById('frame-wrap');
    const statusEl = document.getElementById('status');
    const timerEl = document.getElementById('timer');
    const logEl = document.getElementById('log');
    const goBtn = document.getElementById('go-btn');
    const stopBtn = document.getElementById('stop-btn');
    const sizeBtn = document.getElementById('size-btn');

    let startTime = null, timerInterval = null, lastVisible = Date.now();
    const sizes = ['40vh', 'tiny', 'hidden'];
    let sizeIndex = 0;

    function log(m){ const t=new Date().toLocaleTimeString(); logEl.textContent=`[${t}] ${m}\n`+logEl.textContent; }
    function updateTimer(){ if(!startTime)return; const e=Math.floor((Date.now()-startTime)/1000); timerEl.textContent=`${String(Math.floor(e/60)).padStart(2,'0')}:${String(e%60).padStart(2,'0')}`; }

    function start() {
      try {
        // Tell the iframe to play
        if (frame.contentWindow && frame.contentWindow.startVideo) {
          frame.contentWindow.startVideo();
          log('▶ Called iframe.startVideo()');
        } else {
          log('⚠️ iframe.startVideo not reachable (cross-origin?) — tap the video directly');
        }
        startTime = Date.now();
        timerInterval = setInterval(updateTimer, 250);
        statusEl.textContent = '🎬 Playing (our video in iframe)';
        statusEl.className = 'status playing';
        goBtn.style.display='none'; stopBtn.style.display='block';
      } catch(err) {
        log(`❌ ${err.message}`);
      }
    }

    function stop() {
      try {
        if (frame.contentWindow && frame.contentWindow.stopVideo) frame.contentWindow.stopVideo();
      } catch(e){}
      clearInterval(timerInterval); startTime=null;
      timerEl.textContent='00:00';
      statusEl.textContent='Stopped'; statusEl.className='status';
      goBtn.style.display='block'; stopBtn.style.display='none';
      log('⏹ Stopped');
    }

    function cycleSize() {
      sizeIndex = (sizeIndex+1)%sizes.length;
      const s = sizes[sizeIndex];
      frameWrap.className = 'frame-wrap' + (s==='40vh' ? '' : ' '+s);
      if (s==='40vh') frameWrap.style.height='40vh';
      sizeBtn.textContent = `📐 Size: ${s}`;
      log(`📐 Size: ${s}`);
    }

    goBtn.addEventListener('click', start);
    stopBtn.addEventListener('click', stop);
    sizeBtn.addEventListener('click', cycleSize);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) log('📵 Page hidden (screen locked)');
      else { const h=Math.floor((Date.now()-lastVisible)/1000); log(`📱 Visible (hidden ~${h}s)`); }
      lastVisible = Date.now();
    });

    frame.addEventListener('load', () => log('📂 iframe (player.html) loaded'));

    log(`UA: ${navigator.userAgent.slice(0,60)}...`);
    log('Tap Start. If video stays black, tap directly on it to trigger play.');
  </script>
</body>
</html>
