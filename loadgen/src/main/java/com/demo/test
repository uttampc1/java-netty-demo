// src/utils/beep.js
/**
 * HoldOn — Audio + Haptic helpers for cue playback
 * 
 * Wraps Web Audio API and Vibration API with sensible defaults.
 */

let audioCtx = null;
let audioUnlocked = false;

function getAudioContext() {
  if (!audioCtx) {
    const Ctx = window.AudioContext || window.webkitAudioContext;
    if (!Ctx) return null;
    try {
      audioCtx = new Ctx();
    } catch (err) {
      console.warn('[Audio] Could not create AudioContext:', err);
      return null;
    }
  }
  if (audioCtx.state === 'suspended') {
    audioCtx.resume();
  }
  return audioCtx;
}

/**
 * Unlocks the audio context — MUST be called from a user gesture handler on iOS.
 * Plays a silent sound to satisfy iOS Safari's autoplay restrictions.
 */
export function unlockAudio() {
  if (audioUnlocked) return;
  
  const ctx = getAudioContext();
  if (!ctx) return;
  
  try {
    // Play a 1-sample silent buffer to "warm up" the audio context
    const buffer = ctx.createBuffer(1, 1, 22050);
    const source = ctx.createBufferSource();
    source.buffer = buffer;
    source.connect(ctx.destination);
    source.start(0);
    audioUnlocked = true;
    console.log('[Audio] Context unlocked');
  } catch (err) {
    console.warn('[Audio] Unlock failed:', err);
  }
}

/**
 * Plays a single beep tone.
 * @param {Object} options
 * @param {number} [options.frequency=880] - Hz
 * @param {number} [options.duration=0.15] - seconds
 * @param {number} [options.volume=0.7]    - 0.0 to 1.0
 * @param {number} [options.startAt=0]     - delay in seconds from now
 * @param {string} [options.type='sine']   - oscillator type
 */
export function playBeep({
  frequency = 880,
  duration = 0.15,
  volume = 0.7,
  startAt = 0,
  type = 'sine',
} = {}) {
  const ctx = getAudioContext();
  if (!ctx) return;

  const oscillator = ctx.createOscillator();
  const gainNode = ctx.createGain();

  oscillator.type = type;
  oscillator.frequency.value = frequency;

  const startTime = ctx.currentTime + startAt;
  const endTime = startTime + duration;
  
  // Envelope: quick attack, smooth decay (avoids clicks)
  gainNode.gain.setValueAtTime(0, startTime);
  gainNode.gain.linearRampToValueAtTime(volume, startTime + 0.01);
  gainNode.gain.exponentialRampToValueAtTime(0.001, endTime);

  oscillator.connect(gainNode);
  gainNode.connect(ctx.destination);

  oscillator.start(startTime);
  oscillator.stop(endTime + 0.05);
}

/**
 * Plays a pattern of beeps (sequence).
 * @param {Array<Object>} pattern - Array of beep config objects (with optional `startAt`)
 * @param {number} volume - 0.0 to 1.0 (applied to all beeps in pattern)
 */
export function playBeepPattern(pattern, volume = 0.7) {
  let offset = 0;
  pattern.forEach((beep) => {
    playBeep({
      ...beep,
      volume,
      startAt: offset + (beep.startAt || 0),
    });
    offset += (beep.duration || 0.15) + (beep.gap || 0.05);
  });
}

/**
 * Triggers a vibration. Silently no-ops if unsupported (iOS).
 * @param {number|number[]} pattern - milliseconds, or pattern array like [100, 50, 100]
 */
export function vibrate(pattern = 60) {
  if (typeof navigator !== 'undefined' && typeof navigator.vibrate === 'function') {
    try {
      navigator.vibrate(pattern);
    } catch (err) {
      // ignore
    }
  }
}

/**
 * Speaks text using the Web Speech API. Silently no-ops if unsupported.
 * @param {string} text 
 * @param {Object} options
 * @param {number} [options.volume=1.0]  - 0.0 to 1.0
 * @param {number} [options.rate=1.1]    - speech rate
 * @param {number} [options.pitch=1.0]   - voice pitch
 */
export function speak(text, { volume = 1.0, rate = 1.1, pitch = 1.0 } = {}) {
  if (!('speechSynthesis' in window)) return;
  if (!text) return;
  
  try {
    // Cancel any in-progress speech to prevent queuing up
    window.speechSynthesis.cancel();
    
    const utterance = new SpeechSynthesisUtterance(String(text));
    utterance.volume = volume;
    utterance.rate = rate;
    utterance.pitch = pitch;
    window.speechSynthesis.speak(utterance);
  } catch (err) {
    console.warn('[Speech] Failed:', err);
  }
}

/**
 * Stops any in-progress speech immediately.
 */
export function stopSpeech() {
  if ('speechSynthesis' in window) {
    try {
      window.speechSynthesis.cancel();
    } catch (e) {}
  }
}

// src/core/cueManager.js
/**
 * HoldOn — Cue Manager
 * 
 * Plays audio + haptic cues during a workout session.
 * Reads user preferences from Cue Defaults settings.
 * 
 * Usage:
 *   const cues = new CueManager(cueDefaults);
 *   cues.unlock();  // call once from user gesture
 *   cues.cuePhaseStart('work', { exercise, set });
 *   cues.cueCountdown(3);
 *   cues.cueComplete();
 */

import { playBeep, playBeepPattern, speak, vibrate, unlockAudio, stopSpeech } from '../utils/beep.js';

const DEFAULT_SETTINGS = {
  cueType: 'beep',
  countdownAnnounce: true,
  volume: 70,
};

export class CueManager {
  constructor(settings = {}) {
    this.settings = { ...DEFAULT_SETTINGS, ...settings };
    this._lastAnnouncedSecond = null;  // prevents double-firing for the same second
  }
  
  /**
   * MUST be called from a user-gesture event handler on iOS to unlock audio.
   * Safe to call multiple times.
   */
  unlock() {
    unlockAudio();
  }
  
  /**
   * Updates settings live (e.g., if user changes them during workout).
   */
  updateSettings(settings) {
    this.settings = { ...DEFAULT_SETTINGS, ...settings };
  }
  
  /**
   * Cue for a phase starting.
   * @param {string} phase - 'prep' | 'work' | 'rest-set' | 'rest-exercise'
   * @param {Object} context - { exercise, set, totalSets, isNewExercise }
   */
  cuePhaseStart(phase, context = {}) {
    this._lastAnnouncedSecond = null;  // reset countdown tracker for new phase
    
    const volume = this._normalizedVolume();
    const flags = this._cueFlags();
    
    if (phase === 'prep') {
      if (flags.beep) {
        playBeep({ frequency: 660, duration: 0.2, volume });
      }
      if (flags.voice) {
        speak('Get ready', { volume });
      }
      if (flags.vibration) {
        vibrate(80);
      }
      return;
    }
    
    if (phase === 'work') {
      if (flags.beep) {
        // Two ascending beeps for "start working"
        playBeepPattern([
          { frequency: 800, duration: 0.12 },
          { frequency: 1100, duration: 0.18 },
        ], volume);
      }
      if (flags.voice) {
        const text = this._buildWorkAnnouncement(context);
        speak(text, { volume });
      }
      if (flags.vibration) {
        vibrate([100, 50, 100]);
      }
      return;
    }
    
    if (phase === 'rest-set' || phase === 'rest-exercise') {
      if (flags.beep) {
        // Single lower beep for "rest"
        playBeep({ frequency: 440, duration: 0.25, volume });
      }
      if (flags.voice) {
        const text = phase === 'rest-exercise' && context.nextExerciseName
          ? `Rest. Next: ${context.nextExerciseName}`
          : 'Rest';
        speak(text, { volume });
      }
      if (flags.vibration) {
        vibrate(60);
      }
      return;
    }
  }
  
  /**
   * Plays the countdown cue (3, 2, 1) in the final seconds of a phase.
   * Only fires if countdownAnnounce is enabled in settings.
   * @param {number} secondsRemaining - integer (3, 2, or 1)
   */
  cueCountdown(secondsRemaining) {
    if (!this.settings.countdownAnnounce) return;
    if (secondsRemaining < 1 || secondsRemaining > 3) return;
    if (secondsRemaining === this._lastAnnouncedSecond) return;  // dedupe
    
    this._lastAnnouncedSecond = secondsRemaining;
    
    const volume = this._normalizedVolume();
    const flags = this._cueFlags();
    
    if (flags.beep) {
      // Short tick beep
      playBeep({ frequency: 1000, duration: 0.08, volume: volume * 0.7 });
    }
    if (flags.voice) {
      // Speak the number
      speak(String(secondsRemaining), { volume, rate: 1.4 });
    }
    if (flags.vibration) {
      vibrate(40);
    }
  }
  
  /**
   * Cue for workout completion.
   */
  cueComplete() {
    const volume = this._normalizedVolume();
    const flags = this._cueFlags();
    
    if (flags.beep) {
      // Three ascending beeps — celebratory
      playBeepPattern([
        { frequency: 660, duration: 0.15 },
        { frequency: 880, duration: 0.15 },
        { frequency: 1320, duration: 0.3 },
      ], volume);
    }
    if (flags.voice) {
      speak('Workout complete!', { volume });
    }
    if (flags.vibration) {
      // Long celebratory pattern
      vibrate([200, 100, 200, 100, 400]);
    }
  }
  
  /**
   * Stops any in-progress voice (called when user exits or pauses).
   */
  stop() {
    stopSpeech();
  }
  
  // ============================================================
  // INTERNALS
  // ============================================================
  
  _normalizedVolume() {
    const v = this.settings.volume ?? DEFAULT_SETTINGS.volume;
    return Math.max(0, Math.min(1, v / 100));
  }
  
  /**
   * Returns which cue types are active based on the cueType setting.
   */
  _cueFlags() {
    const type = this.settings.cueType ?? DEFAULT_SETTINGS.cueType;
    return {
      beep:      type === 'beep' || type === 'beep-vibration',
      voice:     type === 'voice' || type === 'voice-vibration',
      vibration: type === 'vibration' || type === 'beep-vibration' || type === 'voice-vibration',
    };
  }
  
  _buildWorkAnnouncement(context) {
    const { exercise, set, totalSets, isNewExercise } = context;
    if (!exercise) return 'Work';
    
    // New exercise — say the name
    if (isNewExercise) {
      return exercise.name;
    }
    
    // Same exercise, new set — say "Set N"
    if (set && totalSets > 1) {
      return `Set ${set}`;
    }
    
    return exercise.name;
  }
}

