  background-color: var(--accent);
  color: white;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exercise-row-main {
  flex: 1;
  min-width: 0;
}

.exercise-row-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 2px;
}

.exercise-row-meta {
  font-size: 13px;
  color: var(--text-muted);
}

.exercise-row-actions {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
}

.btn-icon-only {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  border-radius: 50%;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 14px;
  transition: background-color 0.15s ease, color 0.15s ease;
  -webkit-tap-highlight-color: transparent;
}

.btn-icon-only:hover {
  background-color: rgba(0, 0, 0, 0.05);
  color: var(--text);
}

@media (prefers-color-scheme: dark) {
  .btn-icon-only:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }
}

.btn-icon-danger:hover {
  background-color: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

@media (prefers-color-scheme: dark) {
  .btn-icon-danger:hover {
    background-color: rgba(255, 69, 58, 0.15);
    color: #ff453a;
  }
}

.add-exercise-btn {
  width: 100%;
  justify-content: center;
  margin-top: 8px;
}

