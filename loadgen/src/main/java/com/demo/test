// src/db/importValidation.js
/**
 * HoldOn — Import Validation
 * 
 * Validates that a parsed JSON object is a valid HoldOn backup.
 * Returns either { valid: true, data, summary } or { valid: false, error }.
 */

/**
 * Validate a parsed backup object.
 * @param {*} data - Parsed JSON
 * @returns {Object} { valid, data, summary, error }
 */
export function validateBackup(data) {
  // Must be an object
  if (!data || typeof data !== 'object' || Array.isArray(data)) {
    return {
      valid: false,
      error: 'File is not a valid backup (expected an object at the top level).',
    };
  }
  
  // Must have a version field
  if (typeof data.version !== 'number') {
    return {
      valid: false,
      error: 'File is missing the "version" field. This may not be a HoldOn backup.',
    };
  }
  
  // Must have routines array
  if (!Array.isArray(data.routines)) {
    return {
      valid: false,
      error: 'File is missing the "routines" array.',
    };
  }
  
  // Must have activities array
  if (!Array.isArray(data.activities)) {
    return {
      valid: false,
      error: 'File is missing the "activities" array.',
    };
  }
  
  // Sessions array is optional (older backups may not have it)
  const sessions = Array.isArray(data.sessions) ? data.sessions : [];
  
  // Count seeded vs custom activities for the summary
  const seededActivities = data.activities.filter((a) => a && a.isSeeded === true);
  const customActivities = data.activities.filter((a) => a && a.isSeeded !== true);
  
  // Basic sanity check on routines (must have id and title at minimum)
  const invalidRoutine = data.routines.find((r) => !r || !r.id || typeof r.title !== 'string');
  if (invalidRoutine) {
    return {
      valid: false,
      error: 'One or more routines are malformed (missing id or title).',
    };
  }
  
  // Basic sanity check on activities
  const invalidActivity = data.activities.find((a) => !a || !a.id || typeof a.name !== 'string');
  if (invalidActivity) {
    return {
      valid: false,
      error: 'One or more activities are malformed (missing id or name).',
    };
  }
  
  return {
    valid: true,
    data: {
      ...data,
      sessions,  // ensure sessions is always an array
    },
    summary: {
      version: data.version,
      routineCount: data.routines.length,
      customActivityCount: customActivities.length,
      seededActivityCount: seededActivities.length,
      sessionCount: sessions.length,
      exportedAt: data.exportedAt || null,
    },
  };
}

/**
 * Parse a JSON string and validate it.
 * Returns the same shape as validateBackup, plus catches parse errors.
 */
export function parseAndValidateBackup(jsonString) {
  let parsed;
  try {
    parsed = JSON.parse(jsonString);
  } catch (err) {
    return {
      valid: false,
      error: `Invalid JSON: ${err.message}`,
    };
  }
  
  return validateBackup(parsed);
}

