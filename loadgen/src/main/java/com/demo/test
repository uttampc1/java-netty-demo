// Number field with live validation
  function bindNumberInput(input, errorEl, field, min, max) {
    input.addEventListener('input', (e) => {
      const raw = e.target.value;
      const value = parseInt(raw, 10);
      const isValid = !isNaN(value) && value >= min && value <= max;
      
      draft[field] = isNaN(value) ? min : value;
      
      if (raw === '' || isValid) {
        input.classList.remove('input-error');
        errorEl.hidden = true;
      } else {
        input.classList.add('input-error');
        errorEl.hidden = false;
      }
      
      updateSaveButtonState();
    });
    
    input.addEventListener('blur', (e) => {
      const value = parseInt(e.target.value, 10);
      if (isNaN(value) || e.target.value === '') {
        input.value = min;
        draft[field] = min;
        input.classList.remove('input-error');
        errorEl.hidden = true;
        updateSaveButtonState();
      }
    });
  }
  
  // Check if the form is currently valid (for enabling/disabling save button)
  function isFormValid() {
    const nameOk = (draft.name || '').trim().length > 0;
    const workOk = !isNaN(draft.workDuration) && draft.workDuration >= 0 && draft.workDuration <= 120;
    const restOk = !isNaN(draft.restBetweenSets) && draft.restBetweenSets >= 0 && draft.restBetweenSets <= 120;
    const setsOk = !isNaN(draft.sets) && draft.sets >= 1 && draft.sets <= 20;
    return nameOk && workOk && restOk && setsOk;
  }
  
  function updateSaveButtonState() {
    if (isFormValid()) {
      saveBtn.disabled = false;
      saveBtn.classList.remove('btn-disabled');
    } else {
      saveBtn.disabled = true;
      saveBtn.classList.add('btn-disabled');
    }
  }


