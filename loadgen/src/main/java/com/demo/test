// src/utils/platform.js
/**
 * HoldOn — Platform detection helpers
 * 
 * Used for showing platform-specific UI (e.g., warning about Vibration API on iOS).
 */

/**
 * Detects iOS (iPhone/iPad/iPod, including iPad on iPadOS pretending to be Mac).
 */
export function isIOS() {
  if (typeof navigator === 'undefined') return false;
  
  // Modern iPads report as Mac. Detect via touch points.
  const isIPadOS = navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1;
  
  return /iPad|iPhone|iPod/.test(navigator.userAgent) || isIPadOS;
}

/**
 * Detects whether the Vibration API is actually supported.
 * Returns false on iOS (which doesn't support it) and desktops without vibration hardware.
 */
export function isVibrationSupported() {
  return typeof navigator !== 'undefined'
    && typeof navigator.vibrate === 'function'
    && !isIOS();
}

// src/views/cueDefaultsSection.js
  const vibrationOK = isVibrationSupported();
  
  const cueTypeOptionsHtml = CUE_TYPE_OPTIONS.map((opt) => {
    const involvesVibration = opt.value.includes('vibration');
    const showWarning = involvesVibration && !vibrationOK;
    
    return `
      <label class="radio-row${showWarning ? ' radio-row-unsupported' : ''}">
        <input
          type="radio"
          name="cue-type"
          value="${escapeHtml(opt.value)}"
          ${settings.cueType === opt.value ? 'checked' : ''}
        />
        <div class="radio-row-content">
          <div class="radio-row-label">${escapeHtml(opt.label)}</div>
          <div class="radio-row-description">
            ${escapeHtml(opt.description)}
            ${showWarning ? '<span class="unsupported-note"> · Not supported on this device</span>' : ''}
          </div>
        </div>
      </label>
    `;
  }).join('');
