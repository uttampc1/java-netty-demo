export async function renderPlayer(container, routineId, options = {}) {
  const { exerciseId = null } = options;
  const isSingleExercise = Boolean(exerciseId);

  // --- Single-exercise mode ---
  if (isSingleExercise) {
    const targetExercise = routine.exercises.find(ex => ex.id === exerciseId);
    if (!targetExercise) {
      await alertModal({
        title: 'Exercise not found',
        message: 'That exercise no longer exists in this routine.',
      });
      router.navigate(`/routine/${routineId}`);
      return;
    }
    // Replace routine with a synthetic single-exercise version
    routine = {
      ...routine,
      exercises: [targetExercise],
      restBetweenExercises: 0,
      _isSingleExercise: true,
      _singleExerciseName: targetExercise.name,
      _parentRoutineId: routine.id,
    };
  }

