// src/views/dataSection.js
/**
 * HoldOn — Data Section (rendered inside Settings)
 * 
 * Actions:
 *   - Export all data (download JSON)
 *   - Import data (upload JSON, merge or replace)
 *   - Reset all data (wipe and reseed)
 */

import { exportAllData, importData, getAllRoutines, getAllActivities, getMeta, setMeta } from '../db/store.js';

export async function renderDataSection(container) {
  // Get current counts for the export button label
  const [routines, activities] = await Promise.all([
    getAllRoutines(),
    getAllActivities(),
  ]);
  
  const totals = {
    routines: routines.length,
    activities: activities.length,
  };

  container.innerHTML = `
    <div class="data-section">
      <div class="data-action-row">
        <button type="button" class="data-action-btn" id="export-btn">
          <div class="data-action-content">
            <div class="data-action-label">📤 Export all data</div>
            <div class="data-action-hint">
              Save ${totals.routines} routine${totals.routines === 1 ? '' : 's'} and ${totals.activities} ${totals.activities === 1 ? 'activity' : 'activities'} to a JSON file
            </div>
          </div>
        </button>
      </div>

      <div class="settings-divider"></div>

      <div class="data-action-row">
        <button type="button" class="data-action-btn" id="import-btn">
          <div class="data-action-content">
            <div class="data-action-label">📥 Import data...</div>
            <div class="data-action-hint">Restore from a backup JSON file</div>
          </div>
        </button>
        <input type="file" id="import-file-input" accept="application/json,.json" hidden />
      </div>

      <div class="settings-divider"></div>

      <div class="data-action-row">
        <button type="button" class="data-action-btn data-action-btn-danger" id="reset-btn">
          <div class="data-action-content">
            <div class="data-action-label">🗑 Reset all data</div>
            <div class="data-action-hint">Permanently delete everything and start fresh</div>
          </div>
        </button>
      </div>
    </div>
  `;

  wireDataSection(container);
}

function wireDataSection(container) {
  container.querySelector('#export-btn').addEventListener('click', handleExport);
  container.querySelector('#import-btn').addEventListener('click', () => {
    container.querySelector('#import-file-input').click();
  });
  container.querySelector('#import-file-input').addEventListener('change', handleImportFile);
  container.querySelector('#reset-btn').addEventListener('click', handleReset);
}

// ============================================================
// EXPORT
// ============================================================

async function handleExport() {
  try {
    const data = await exportAllData();
    
    // Build filename: holdon-backup-2025-01-15.json
    const date = new Date().toISOString().split('T')[0];  // YYYY-MM-DD
    const filename = `holdon-backup-${date}.json`;
    
    // Convert to JSON string (pretty-printed for readability)
    const jsonString = JSON.stringify(data, null, 2);
    
    // Create blob and trigger download
    const blob = new Blob([jsonString], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    
    // Clean up the blob URL after a short delay
    setTimeout(() => URL.revokeObjectURL(url), 1000);
    
    console.log('[Data] Exported:', filename);
  } catch (err) {
    console.error('[Data] Export failed:', err);
    alert('Export failed: ' + err.message);
  }
}

