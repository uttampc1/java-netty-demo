/* === Step 1.4.F.1 — Settings Screen + Gear Icon === */

/* Home header with action button (gear icon) */
.app-header-with-action {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  text-align: left;
}

.app-header-with-action .app-header-content {
  flex: 1;
  text-align: center;
  /* offset to visually center title accounting for gear icon */
  padding-left: 40px;
}

.app-header-with-action h1,
.app-header-with-action .tagline {
  text-align: center;
}

.settings-icon-btn {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.15s ease, color 0.15s ease;
  -webkit-tap-highlight-color: transparent;
  margin-top: 4px;
}

.settings-icon-btn:hover {
  background-color: var(--bg-elevated);
  color: var(--text);
}

.settings-icon-btn:active {
  transform: scale(0.95);
}

/* Settings screen layout */
.settings-section {
  margin-bottom: 28px;
}

.settings-section-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 10px 4px;
}

.settings-card {
  background-color: var(--bg-elevated);
  border-radius: var(--radius);
  padding: 4px 0;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.settings-placeholder {
  text-align: center;
  padding: 24px 16px;
  margin: 0;
  font-size: 14px;
}
