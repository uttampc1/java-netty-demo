// src/db/store.js
/**
 * Wipes EVERYTHING — all stores including settings and meta.
 * Used by the Reset feature. Caller is responsible for re-seeding afterward.
 */
export async function wipeAllData() {
  const db = await getDB();
  const tx = db.transaction(
    [STORE_ROUTINES, STORE_ACTIVITIES, STORE_SESSIONS, STORE_META],
    'readwrite'
  );
  
  await tx.objectStore(STORE_ROUTINES).clear();
  await tx.objectStore(STORE_ACTIVITIES).clear();
  await tx.objectStore(STORE_SESSIONS).clear();
  await tx.objectStore(STORE_META).clear();
  
  await tx.done;
  
  console.log('[Reset] All data wiped from all stores.');
}


