// src/db/store.js
export async function createSession({ routineId, routineTitle, totalExercises, totalSets }) {
  const db = await getDB();
  const session = {
    id: generateId(),
    routineId,
    routineTitle,
    startedAt: Date.now(),
    completedAt: null,
    status: 'in-progress',
    totalElapsed: 0,
    exercisesCompleted: 0,
    totalExercises,
    setsCompleted: 0,
    totalSets,
    // Resume fields — updated on every phase transition
    lastExerciseId: null,
    lastExerciseName: null,
    lastExerciseIndex: 0,
    lastSet: 1,
    lastPhase: null,
    lastTimeRemaining: 0,
    lastSavedAt: Date.now(),
  };
  await db.put(STORE_SESSIONS, session);
  return session;
}

/**
 * Returns the most recent in-progress session for a given routine,
 * if it exists and is less than 4 hours old. Otherwise returns null.
 */
export async function findResumableSession(routineId) {
  const db = await getDB();
  const all = await db.getAllFromIndex(STORE_SESSIONS, 'routineId', routineId);
  const MAX_AGE_MS = 4 * 60 * 60 * 1000;  // 4 hours
  const now = Date.now();

  // Find the most recent in-progress session for this routine
  const candidate = all
    .filter(s =>
      s.status === 'in-progress' &&
      s.lastPhase !== null &&
      (now - s.startedAt) < MAX_AGE_MS
    )
    .sort((a, b) => b.startedAt - a.startedAt)[0];

  return candidate || null;
}

/**
 * Marks all stale in-progress sessions as abandoned.
 * Call once on app startup to clean up crash/close leftovers.
 */
export async function abandonStaleSessions() {
  const db = await getDB();
  const all = await db.getAll(STORE_SESSIONS);
  const MAX_AGE_MS = 4 * 60 * 60 * 1000;
  const now = Date.now();

  const stale = all.filter(s =>
    s.status === 'in-progress' &&
    (now - s.startedAt) >= MAX_AGE_MS
  );

  for (const s of stale) {
    await db.put(STORE_SESSIONS, {
      ...s,
      status: 'abandoned',
      completedAt: now,
    });
  }

  if (stale.length > 0) {
    console.log(`[Store] Marked ${stale.length} stale session(s) as abandoned`);
  }
}

