//  src/views/player.js
/**
 * HoldOn — Session Player (Workout Runner)
 * 
 * Full-screen view that guides user through a workout routine.
 * Step 2.1: Static skeleton. Timer engine and cues come in 2.2+.
 * 
 * Route: #/play/:routineId
 */

import { getRoutine } from '../db/store.js';
import { router } from '../utils/router.js';
import { confirmModal, alertModal } from '../components/dialog.js';

export async function renderPlayer(container, routineId) {
  let routine;
  try {
    routine = await getRoutine(routineId);
  } catch (err) {
    console.error('[Player] Failed to load routine:', err);
    await alertModal({
      title: 'Could not load routine',
      message: err.message || 'The routine could not be found.',
    });
    router.navigate('/');
    return;
  }
  
  if (!routine) {
    await alertModal({
      title: 'Routine not found',
      message: 'This routine no longer exists.',
    });
    router.navigate('/');
    return;
  }
  
  if (!routine.exercises || routine.exercises.length === 0) {
    await alertModal({
      title: 'No exercises',
      message: 'This routine has no exercises. Add some first!',
    });
    router.navigate(`/routine/${routineId}`);
    return;
  }
  
  // Initial display state (static for Step 2.1 — driven by timer engine in 2.3)
  const initialState = {
    routine,
    currentExerciseIndex: 0,
    currentSet: 1,
    phase: 'prep',  // 'prep' | 'work' | 'rest-set' | 'rest-exercise' | 'complete'
    timeRemaining: 3,  // seconds — will be dynamic in 2.2
  };
  
  renderPlayerUI(container, initialState);
}

function renderPlayerUI(container, state) {
  const { routine, currentExerciseIndex, currentSet, phase, timeRemaining } = state;
  const currentExercise = routine.exercises[currentExerciseIndex];
  
  const phaseInfo = getPhaseInfo(phase);
  const nextUp = getNextUpLabel(state);
  
  container.innerHTML = `
    <div class="player" data-phase="${phase}">
      <div class="player-top">
        <div class="player-routine-title">${escapeHtml(routine.title)}</div>
      </div>
      
      <div class="player-main">
        <div class="player-exercise-name">${escapeHtml(currentExercise.name)}</div>
        
        ${currentExercise.sets > 1 ? `
          <div class="player-set-counter">Set ${currentSet} of ${currentExercise.sets}</div>
        ` : ''}
        
        <div class="player-phase-label">
          <span class="player-phase-dot"></span>
          ${escapeHtml(phaseInfo.label)}
        </div>
        
        <div class="player-timer" id="player-timer">${formatTime(timeRemaining)}</div>
        
        ${nextUp ? `
          <div class="player-next">${escapeHtml(nextUp)}</div>
        ` : ''}
      </div>
      
      <div class="player-controls">
        <button type="button" class="player-control-btn player-pause-btn" id="player-pause-btn">
          <span class="player-control-icon">⏸</span>
          <span class="player-control-label">Pause</span>
        </button>
        <button type="button" class="player-control-btn player-skip-btn" id="player-skip-btn">
          <span class="player-control-icon">⏭</span>
          <span class="player-control-label">Skip</span>
        </button>
        <button type="button" class="player-control-btn player-exit-btn" id="player-exit-btn">
          <span class="player-control-icon">✕</span>
          <span class="player-control-label">Exit</span>
        </button>
      </div>
    </div>
  `;
  
  wirePlayerControls(container, state);
}

function wirePlayerControls(container, state) {
  const pauseBtn = container.querySelector('#player-pause-btn');
  const skipBtn = container.querySelector('#player-skip-btn');
  const exitBtn = container.querySelector('#player-exit-btn');
  
  pauseBtn.addEventListener('click', async () => {
    // Placeholder for Step 2.5
    await alertModal({
      title: 'Pause',
      message: 'Pause/resume coming in Step 2.5.',
    });
  });
  
  skipBtn.addEventListener('click', async () => {
    // Placeholder for Step 2.5
    await alertModal({
      title: 'Skip',
      message: 'Skip control coming in Step 2.5.',
    });
  });
  
  exitBtn.addEventListener('click', async () => {
    const confirmed = await confirmModal({
      title: 'Exit workout?',
      message: 'Your progress will not be saved.',
      confirmLabel: 'Exit',
      cancelLabel: 'Keep going',
      danger: true,
    });
    if (confirmed) {
      router.navigate(`/routine/${state.routine.id}`);
    }
  });
}

