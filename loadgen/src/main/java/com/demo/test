// src/components/activityPicker.js:
/**
 * HoldOn — Activity Picker
 * 
 * Opens a modal showing all library activities. User picks one,
 * and it gets snapshotted into the routine.
 * 
 * Also has a "Create New Activity" button (wired in 1.4.E.3).
 */

import { getAllActivities } from '../db/store.js';
import { createExerciseSnapshot } from '../db/seed.js';
import { openModal, closeModal } from './modal.js';

/**
 * Opens the activity picker modal.
 * @param {Object} options
 * @param {Function} options.onPick - Called with (exerciseSnapshot) when user picks an activity
 * @param {Function} [options.onCreateNew] - Called when user taps "Create New Activity" (1.4.E.3)
 */
export async function openActivityPicker({ onPick, onCreateNew }) {
  const activities = await getAllActivities();
  
  // Build content
  const content = document.createElement('div');
  content.className = 'activity-picker';
  
  if (activities.length === 0) {
    content.innerHTML = `
      <p class="muted picker-empty">No activities in your library yet.</p>
    `;
  } else {
    const listHtml = activities.map((activity) => `
      <button
        type="button"
        class="picker-item"
        data-activity-id="${escapeHtml(activity.id)}"
      >
        <div class="picker-item-main">
          <div class="picker-item-name">${escapeHtml(activity.name)}</div>
          ${activity.description ? `<div class="picker-item-desc">${escapeHtml(activity.description)}</div>` : ''}
          <div class="picker-item-meta">
            ${activity.defaultWorkDuration}s · ${activity.defaultSets} set${activity.defaultSets === 1 ? '' : 's'}
          </div>
        </div>
        <div class="picker-item-chevron">+</div>
      </button>
    `).join('');
    
    content.innerHTML = `
      <p class="picker-section-label">Choose from your library</p>
      <div class="picker-list">${listHtml}</div>
    `;
  }
  
  // Add "Create New" button
  const createNewBtn = document.createElement('button');
  createNewBtn.type = 'button';
  createNewBtn.className = 'btn btn-secondary picker-create-new';
  createNewBtn.innerHTML = '<span class="btn-icon">+</span><span>Create New Activity</span>';
  
  const divider = document.createElement('div');
  divider.className = 'picker-divider';
  divider.innerHTML = '<span>or</span>';
  
  content.appendChild(divider);
  content.appendChild(createNewBtn);
  
  // Open the modal
  const modal = openModal({
    title: 'Add Exercise',
    content,
  });
  
  // Wire up activity item clicks
  content.querySelectorAll('.picker-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.activityId;
      const activity = activities.find((a) => a.id === id);
      if (activity) {
        const snapshot = createExerciseSnapshot(activity);
        closeModal(modal);
        if (typeof onPick === 'function') {
          // Small delay to let modal close animation play
          setTimeout(() => onPick(snapshot), 100);
        }
      }
    });
  });
  
  // Wire up "Create New" button
  createNewBtn.addEventListener('click', () => {
    closeModal(modal);
    if (typeof onCreateNew === 'function') {
      setTimeout(() => onCreateNew(), 100);
    } else {
      // Placeholder for 1.4.E.3
      setTimeout(() => {
        alert('Create New Activity coming in Step 1.4.E.3!');
      }, 100);
    }
  });
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

// src/views/routineEdit.js
/**
 * HoldOn — Routine Edit View
 * 
 * Unified form for creating a new routine or editing an existing one.
 * Step 1.4.E.2 — Exercise list + activity picker.
 */

import { getRoutine, createRoutine, updateRoutine } from '../db/store.js';
import { router } from '../utils/router.js';
import { openActivityPicker } from '../components/activityPicker.js';

export async function renderRoutineEdit(container, routineId = null) {
  const isEditMode = !!routineId;
  let routine;
  
  if (isEditMode) {
    routine = await getRoutine(routineId);
    if (!routine) {
      container.innerHTML = `
        <main class="container">
          <header class="screen-header">
            <button class="btn-link" id="back-btn">← Back</button>
            <h2>Not Found</h2>
            <div class="header-spacer"></div>
          </header>
          <section class="status-card">
            <p>This routine doesn't exist.</p>
          </section>
        </main>
      `;
      container.querySelector('#back-btn').addEventListener('click', () => router.navigate('/'));
      return;
    }
  } else {
    routine = {
      title: '',
      description: '',
      restBetweenExercises: 15,
      exercises: [],
      useGlobalCues: true,
      cueType: 'beep',
      countdownAnnounce: true,
      tags: [],
      metadata: {},
    };
  }

  // Local working copy — changes are only persisted on Save
  const draft = { ...routine, exercises: [...(routine.exercises || [])] };

  container.innerHTML = `
    <main class="container">
      <header class="screen-header">
        <button class="btn-link" id="cancel-btn">Cancel</button>
        <h2>${isEditMode ? 'Edit Routine' : 'New Routine'}</h2>
        <button class="btn-link btn-link-bold" id="save-btn">Save</button>
      </header>

      <form class="routine-form" id="routine-form" autocomplete="off">
        <div class="form-group">
          <label for="field-title">Title</label>
          <input
            type="text"
            id="field-title"
            name="title"
            placeholder="e.g., Lower Back Strengthening"
            value="${escapeHtml(draft.title)}"
            maxlength="100"
            required
          />
        </div>

        <div class="form-group">
          <label for="field-description">Description <span class="form-label-hint">(optional)</span></label>
          <textarea
            id="field-description"
            name="description"
            placeholder="e.g., A gentle routine for daily practice."
            rows="3"
            maxlength="500"
          >${escapeHtml(draft.description)}</textarea>
        </div>

        <div class="form-group">
          <label for="field-rest">
            Rest between exercises
            <span class="form-label-hint">(0–120 seconds)</span>
          </label>
          <div class="number-input-wrapper">
            <input
              type="number"
              id="field-rest"
              name="restBetweenExercises"
              min="0"
              max="120"
              step="1"
              value="${draft.restBetweenExercises}"
              aria-describedby="field-rest-hint"
            />
            <span class="number-input-suffix">sec</span>
          </div>
          <p class="form-hint" id="field-rest-hint">Pause time when moving from one exercise to the next.</p>
          <p class="form-error" id="field-rest-error" hidden>Please enter a value between 0 and 120.</p>
        </div>

        <div class="form-section-divider"></div>

        <div class="form-group">
          <h3 class="section-heading">Exercises</h3>
          <div id="exercises-container"></div>
          <button type="button" class="btn btn-secondary add-exercise-btn" id="add-exercise-btn">
            <span class="btn-icon">+</span>
            <span>Add Exercise</span>
          </button>
        </div>
      </form>
    </main>
  `;

  // Wire up form handlers
  const form = container.querySelector('#routine-form');
  const titleInput = container.querySelector('#field-title');
  const descInput = container.querySelector('#field-description');
  const restInput = container.querySelector('#field-rest');
  const saveBtn = container.querySelector('#save-btn');
  const cancelBtn = container.querySelector('#cancel-btn');
  const restErrorEl = container.querySelector('#field-rest-error');
  const exercisesContainer = container.querySelector('#exercises-container');
  const addExerciseBtn = container.querySelector('#add-exercise-btn');
  
  // Live-update draft as user types
  titleInput.addEventListener('input', (e) => {
    draft.title = e.target.value;
  });
  descInput.addEventListener('input', (e) => {
    draft.description = e.target.value;
  });
  
  restInput.addEventListener('input', (e) => {
    const raw = e.target.value;
    const value = parseInt(raw, 10);
    const isValid = !isNaN(value) && value >= 0 && value <= 120;
    
    draft.restBetweenExercises = isNaN(value) ? 0 : value;
    
    if (raw === '' || isValid) {
      restInput.classList.remove('input-error');
      restErrorEl.hidden = true;
    } else {
      restInput.classList.add('input-error');
      restErrorEl.hidden = false;
    }
  });
  
  restInput.addEventListener('blur', (e) => {
    const value = parseInt(e.target.value, 10);
    if (isNaN(value) || e.target.value === '') {
      restInput.value = 0;
      draft.restBetweenExercises = 0;
      restInput.classList.remove('input-error');
      restErrorEl.hidden = true;
    }
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    handleSave();
  });

  cancelBtn.addEventListener('click', () => {
    if (isEditMode) {
      router.navigate(`/routine/${routineId}`);
    } else {
      router.navigate('/');
    }
  });

  // ============================================================
  // Exercise list rendering
  // ============================================================
  
  function renderExerciseList() {
    if (!draft.exercises || draft.exercises.length === 0) {
      exercisesContainer.innerHTML = `
        <div class="exercise-empty">
          <p class="muted">No exercises yet. Tap "+ Add Exercise" below to get started.</p>
        </div>
      `;
      return;
    }
    
    exercisesContainer.innerHTML = draft.exercises.map((ex, i) => `
      <article class="exercise-row" data-exercise-id="${escapeHtml(ex.id)}">
        <div class="exercise-row-position">${i + 1}</div>
        <div class="exercise-row-main">
          <div class="exercise-row-name">${escapeHtml(ex.name)}</div>
          <div class="exercise-row-meta">
            ${ex.workDuration}s × ${ex.sets} set${ex.sets === 1 ? '' : 's'}${ex.sets > 1 && ex.restBetweenSets > 0 ? ` · ${ex.restBetweenSets}s rest` : ''}
          </div>
        </div>
        <div class="exercise-row-actions">
          <button type="button" class="btn-icon-only" data-action="edit" data-exercise-id="${escapeHtml(ex.id)}" aria-label="Edit exercise">✎</button>
          <button type="button" class="btn-icon-only btn-icon-danger" data-action="remove" data-exercise-id="${escapeHtml(ex.id)}" aria-label="Remove exercise">✕</button>
        </div>
      </article>
    `).join('');
    
    exercisesContainer.querySelectorAll('[data-action="remove"]').forEach((btn) => {
      btn.addEventListener('click', () => handleRemoveExercise(btn.dataset.exerciseId));
    });
    exercisesContainer.querySelectorAll('[data-action="edit"]').forEach((btn) => {
      btn.addEventListener('click', () => handleEditExercise(btn.dataset.exerciseId));
    });
  }
  
  function handleRemoveExercise(exerciseId) {
    const exercise = draft.exercises.find((e) => e.id === exerciseId);
    if (!exercise) return;
    
    const confirmed = confirm(`Remove "${exercise.name}" from this routine?`);
    if (!confirmed) return;
    
    draft.exercises = draft.exercises.filter((e) => e.id !== exerciseId);
    renderExerciseList();
  }
  
  function handleEditExercise(exerciseId) {
    // Placeholder for 1.4.E.3 — inline exercise editor
    alert('Inline exercise editor coming in Step 1.4.E.3!\n\nFor now, you can remove and re-add the exercise to change it.');
  }
  
  function handleAddExercise() {
    openActivityPicker({
      onPick: (snapshot) => {
        draft.exercises.push(snapshot);
        renderExerciseList();
      },
      // onCreateNew will be wired in 1.4.E.3
    });
  }
  
  addExerciseBtn.addEventListener('click', handleAddExercise);
  
  // Initial render of exercise list
  renderExerciseList();

  // ============================================================
  // Save handler
  // ============================================================
  
  async function handleSave() {
    const trimmedTitle = (draft.title || '').trim();
    if (!trimmedTitle) {
      alert('Please enter a title for your routine.');
      titleInput.focus();
      return;
    }
    
    const rest = draft.restBetweenExercises;
    if (isNaN(rest) || rest < 0 || rest > 120) {
      alert('Please enter a rest time between 0 and 120 seconds.');
      restInput.focus();
      restInput.select();
      return;
    }
    
    draft.title = trimmedTitle;
    draft.description = (draft.description || '').trim();

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      let savedRoutine;
      if (isEditMode) {
        savedRoutine = await updateRoutine(draft);
      } else {
        savedRoutine = await createRoutine(draft);
      }
      router.navigate(`/routine/${savedRoutine.id}`);
    } catch (err) {
      console.error('Failed to save routine:', err);
      alert('Failed to save: ' + err.message);
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save';
    }
  }

  saveBtn.addEventListener('click', handleSave);

  if (!isEditMode) {
    setTimeout(() => titleInput.focus(), 50);
  }
}

function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

