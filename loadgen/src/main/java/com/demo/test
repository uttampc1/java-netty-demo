// JS Handler
function updateWakeLockIndicator(status) {
  const el = document.getElementById('wakelock-indicator');
  if (!el) return;
  const label = el.querySelector('.label');

  if (!status.supported) {
    el.hidden = false;
    el.classList.add('unsupported');
    label.textContent = 'Screen may sleep (browser unsupported)';
    return;
  }

  el.classList.remove('unsupported');

  if (status.active) {
    el.hidden = false;
    label.textContent = 'Screen lock on';
  } else {
    // released or off — hide unless a workout is still wanted
    el.hidden = true;
  }
}



