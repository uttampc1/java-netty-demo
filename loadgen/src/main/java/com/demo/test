import { getRoutine, createRoutine, updateRoutine } from '../db/store.js';
import { router } from '../utils/router.js';
import { openActivityPicker } from '../components/activityPicker.js';
import { openExerciseEditor } from '../components/exerciseEditor.js';

function handleEditExercise(exerciseId) {
    const exercise = draft.exercises.find((e) => e.id === exerciseId);
    if (!exercise) return;
    
    openExerciseEditor({
      mode: 'edit',
      exercise,
      onSave: (updatedSnapshot) => {
        // Replace the exercise in the draft with the updated version
        const idx = draft.exercises.findIndex((e) => e.id === exerciseId);
        if (idx !== -1) {
          draft.exercises[idx] = updatedSnapshot;
          renderExerciseList();
        }
      },
    });
  }

function handleAddExercise() {
    openActivityPicker({
      onPick: (snapshot) => {
        draft.exercises.push(snapshot);
        renderExerciseList();
      },
      onCreateNew: () => {
        openExerciseEditor({
          mode: 'create',
          onSave: (newSnapshot) => {
            draft.exercises.push(newSnapshot);
            renderExerciseList();
          },
        });
      },
    });
  }

