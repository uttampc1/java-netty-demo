/* === Import Confirmation Modal === */

.import-confirm {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.import-confirm-intro {
  margin: 0;
  font-size: 14px;
  line-height: 1.5;
  color: var(--text);
}

.import-summary {
  background-color: var(--bg-elevated);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  padding: 14px 16px;
}

.import-summary-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 10px;
}

.import-summary-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.import-summary-list li {
  display: flex;
  align-items: baseline;
  gap: 8px;
  font-size: 14px;
  flex-wrap: wrap;
}

.import-summary-count {
  display: inline-block;
  min-width: 24px;
  font-weight: 600;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}

.import-summary-label {
  color: var(--text);
}

.import-summary-skipped .import-summary-count,
.import-summary-skipped .import-summary-label {
  color: var(--text-muted);
}

.import-summary-note {
  font-size: 12px;
  color: #ff9500;
  font-style: italic;
  margin-left: 4px;
}

@media (prefers-color-scheme: dark) {
  .import-summary-note {
    color: #ff9f0a;
  }
}

.import-confirm-question {
  margin: 4px 0 0 0;
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
}

/* Action buttons (Replace / Merge) */
.import-action-btn {
  display: flex;
  align-items: center;
  width: 100%;
  background-color: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  font-family: inherit;
  text-align: left;
  cursor: pointer;
  transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.05s ease;
  -webkit-tap-highlight-color: transparent;
}

.import-action-btn:hover {
  background-color: rgba(0, 122, 255, 0.05);
  border-color: var(--accent);
}

@media (prefers-color-scheme: dark) {
  .import-action-btn:hover {
    background-color: rgba(10, 132, 255, 0.1);
  }
}

.import-action-btn:active {
  transform: scale(0.99);
}

.import-action-content {
  flex: 1;
  min-width: 0;
}

.import-action-label {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.import-action-hint {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.4;
}
