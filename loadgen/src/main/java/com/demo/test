// style.css
/* === Step 1.4.F.3.B — Data Section === */

.data-section {
  padding: 4px 0;
}

.data-action-row {
  padding: 0;
}

.data-action-btn {
  display: flex;
  align-items: center;
  width: 100%;
  background: none;
  border: none;
  padding: 14px 16px;
  font-family: inherit;
  text-align: left;
  cursor: pointer;
  transition: background-color 0.15s ease;
  -webkit-tap-highlight-color: transparent;
}

.data-action-btn:hover {
  background-color: rgba(0, 0, 0, 0.03);
}

@media (prefers-color-scheme: dark) {
  .data-action-btn:hover {
    background-color: rgba(255, 255, 255, 0.04);
  }
}

.data-action-btn:active {
  background-color: rgba(0, 0, 0, 0.06);
}

@media (prefers-color-scheme: dark) {
  .data-action-btn:active {
    background-color: rgba(255, 255, 255, 0.08);
  }
}

.data-action-content {
  flex: 1;
  min-width: 0;
}

.data-action-label {
  font-size: 15px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 2px;
}

.data-action-hint {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.4;
}

/* Danger variant for Reset */
.data-action-btn-danger .data-action-label {
  color: #ff3b30;
}

@media (prefers-color-scheme: dark) {
  .data-action-btn-danger .data-action-label {
    color: #ff453a;
  }
}

.data-action-btn-danger:hover {
  background-color: rgba(255, 59, 48, 0.05);
}

@media (prefers-color-scheme: dark) {
  .data-action-btn-danger:hover {
    background-color: rgba(255, 69, 58, 0.08);
  }
}

