async function handleReset() {
  showResetWarning();
}

/**
 * Modal 1: Initial warning with option to export first.
 */
function showResetWarning() {
  const content = document.createElement('div');
  content.className = 'reset-warning';
  content.innerHTML = `
    <div class="reset-warning-icon">⚠️</div>
    
    <p class="reset-warning-title">This will delete everything.</p>
    
    <div class="reset-warning-list">
      <p>You're about to permanently delete:</p>
      <ul>
        <li>All routines</li>
        <li>All custom activities</li>
        <li>All workout history (sessions)</li>
        <li>All settings (cue defaults)</li>
      </ul>
      <p class="reset-warning-note">
        Seeded activities will be restored to defaults.
        <strong>This action cannot be undone.</strong>
      </p>
    </div>
    
    <div class="reset-warning-backup">
      <p class="reset-warning-backup-title">💾 Recommended: Back up first</p>
      <p class="reset-warning-backup-hint">
        Export your data now so you can restore it later if you change your mind.
      </p>
      <button type="button" class="btn btn-secondary reset-export-btn" id="reset-export-btn">
        📤 Export now
      </button>
    </div>
    
    <div class="editor-actions reset-actions">
      <button type="button" class="btn btn-secondary" id="reset-cancel-btn">Cancel</button>
      <button type="button" class="btn btn-danger" id="reset-continue-btn">Continue to reset</button>
    </div>
  `;
  
  const modal = openModal({
    title: 'Reset All Data',
    content,
  });
  
  content.querySelector('#reset-cancel-btn').addEventListener('click', () => {
    closeModal(modal);
  });
  
  content.querySelector('#reset-export-btn').addEventListener('click', () => {
    // Trigger export without closing this modal — user can come back to it
    handleExport();
  });
  
  content.querySelector('#reset-continue-btn').addEventListener('click', () => {
    closeModal(modal);
    setTimeout(() => showResetConfirm(), 200);
  });
}

/**
 * Modal 2: Type DELETE to enable the destructive button.
 */
function showResetConfirm() {
  const content = document.createElement('div');
  content.className = 'reset-confirm';
  content.innerHTML = `
    <p class="reset-confirm-intro">
      Type <strong>DELETE</strong> below to confirm.
      This is your last chance to cancel.
    </p>
    
    <div class="form-group">
      <input
        type="text"
        id="reset-confirm-input"
        class="reset-confirm-input"
        placeholder="Type DELETE"
        autocomplete="off"
        autocapitalize="characters"
        spellcheck="false"
      />
    </div>
    
    <div class="editor-actions reset-actions">
      <button type="button" class="btn btn-secondary" id="reset-confirm-cancel">Cancel</button>
      <button type="button" class="btn btn-danger" id="reset-confirm-delete" disabled>
        Delete Everything
      </button>
    </div>
  `;
  
  const modal = openModal({
    title: 'Final Confirmation',
    content,
    dismissable: false,  // require explicit Cancel — no accidental backdrop dismiss
  });
  
  const input = content.querySelector('#reset-confirm-input');
  const deleteBtn = content.querySelector('#reset-confirm-delete');
  const cancelBtn = content.querySelector('#reset-confirm-cancel');
  
  input.addEventListener('input', (e) => {
    const value = e.target.value;
    if (value === 'DELETE') {
      deleteBtn.disabled = false;
      deleteBtn.classList.remove('btn-disabled');
    } else {
      deleteBtn.disabled = true;
      deleteBtn.classList.add('btn-disabled');
    }
  });
  
  cancelBtn.addEventListener('click', () => closeModal(modal));
  
  deleteBtn.addEventListener('click', async () => {
    closeModal(modal);
    setTimeout(() => executeReset(), 200);
  });
  
  setTimeout(() => input.focus(), 100);
}

/**
 * Actually wipe + re-seed, then show success.
 */
async function executeReset() {
  const loadingContent = document.createElement('div');
  loadingContent.className = 'import-loading';
  loadingContent.innerHTML = `
    <p class="import-loading-text">Resetting all data...</p>
  `;
  const loadingModal = openModal({
    title: 'Resetting...',
    content: loadingContent,
    dismissable: false,
  });
  
  try {
    await wipeAllData();
    await seedIfNeeded();  // re-seeds activities + sample routine
    
    closeModal(loadingModal);
    setTimeout(() => showResetSuccess(), 200);
  } catch (err) {
    console.error('[Reset] Failed:', err);
    closeModal(loadingModal);
    setTimeout(() => {
      alert('Reset failed:\n\n' + err.message);
    }, 200);
  }
}

function showResetSuccess() {
  const content = document.createElement('div');
  content.className = 'import-success';
  content.innerHTML = `
    <div class="import-success-icon">✅</div>
    <p class="import-success-title">Reset complete!</p>
    <p class="reset-success-hint">
      Your app has been restored to its initial state with default activities and a sample routine.
    </p>
    
    <div class="editor-actions">
      <button type="button" class="btn btn-primary" id="reset-success-done">Done</button>
    </div>
  `;
  
  const modal = openModal({
    title: 'Success',
    content,
    dismissable: false,
  });
  
  content.querySelector('#reset-success-done').addEventListener('click', () => {
    closeModal(modal);
    setTimeout(() => {
      router.navigate('/');
    }, 200);
  });
}


