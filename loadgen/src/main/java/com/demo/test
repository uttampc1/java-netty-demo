/**
 * HoldOn — Platform Detection
 * 
 * Returns the user's platform for showing platform-specific UI/instructions.
 * Uses navigator.userAgent + a few quirks (iPadOS 13+ pretends to be Mac).
 * 
 * Returns one of: 'ios' | 'android' | 'desktop'
 * 
 * Note: This is "good enough" detection, not bulletproof. Edge cases:
 * - iPadOS 13+ reports as MacIntel by default → detected via touch support
 * - User agent can be spoofed
 * - Some browsers randomize UA (Brave, DuckDuckGo)
 */

let cachedPlatform = null;

/**
 * Returns 'ios', 'android', or 'desktop'.
 * Result is cached after first call (platform doesn't change at runtime).
 */
export function getPlatform() {
  if (cachedPlatform) return cachedPlatform;
  
  if (typeof navigator === 'undefined') {
    cachedPlatform = 'desktop';
    return cachedPlatform;
  }
  
  const ua = navigator.userAgent || '';
  const platform = navigator.platform || '';
  
  // iOS detection (iPhone, iPod, iPad on older iOS)
  if (/iPhone|iPod/.test(ua)) {
    cachedPlatform = 'ios';
    return cachedPlatform;
  }
  
  // iPad on iOS 12 and earlier
  if (/iPad/.test(ua)) {
    cachedPlatform = 'ios';
    return cachedPlatform;
  }
  
  // iPad on iPadOS 13+ — reports as MacIntel but has touch support
  // This is the tricky one: Apple decided iPads should look like Macs in UA
  if (platform === 'MacIntel' && navigator.maxTouchPoints > 1) {
    cachedPlatform = 'ios';
    return cachedPlatform;
  }
  
  // Android detection
  if (/Android/.test(ua)) {
    cachedPlatform = 'android';
    return cachedPlatform;
  }
  
  // Default: desktop (Windows, Mac, Linux, ChromeOS)
  cachedPlatform = 'desktop';
  return cachedPlatform;
}

/**
 * Convenience: returns true if running on iOS (iPhone or iPad).
 */
export function isIOS() {
  return getPlatform() === 'ios';
}

/**
 * Convenience: returns true if running on Android.
 */
export function isAndroid() {
  return getPlatform() === 'android';
}

/**
 * Convenience: returns true if running on desktop (Windows/Mac/Linux/ChromeOS).
 */
export function isDesktop() {
  return getPlatform() === 'desktop';
}

/**
 * Returns true if running as an installed PWA (standalone display mode).
 * Useful for showing different UI in "installed" vs "browser" contexts.
 */
export function isStandalone() {
  if (typeof window === 'undefined') return false;
  
  // Standard PWA detection
  if (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches) {
    return true;
  }
  
  // iOS Safari uses navigator.standalone (non-standard)
  if (navigator.standalone === true) {
    return true;
  }
  
  return false;
}

/**
 * For testing: resets the cached platform (so getPlatform() recomputes).
 * Don't use in production code.
 */
export function _resetPlatformCache() {
  cachedPlatform = null;
}
