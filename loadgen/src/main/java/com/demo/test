// src/views/dataSection.js
function processImportData(jsonString) {
  const result = parseAndValidateBackup(jsonString);
  
  if (!result.valid) {
    alert('Import failed:\n\n' + result.error);
    return;
  }
  
  showImportConfirmation(result.data, result.summary);
}

function showImportConfirmation(data, summary) {
  const exportedDate = summary.exportedAt 
    ? new Date(summary.exportedAt).toLocaleDateString(undefined, {
        year: 'numeric', month: 'short', day: 'numeric',
      })
    : null;
  
  const content = document.createElement('div');
  content.className = 'import-confirm';
  content.innerHTML = `
    <p class="import-confirm-intro">
      Valid HoldOn backup${exportedDate ? ` from <strong>${escapeHtml(exportedDate)}</strong>` : ''}.
    </p>
    
    <div class="import-summary">
      <div class="import-summary-title">This backup contains:</div>
      <ul class="import-summary-list">
        <li>
          <span class="import-summary-count">${summary.routineCount}</span>
          <span class="import-summary-label">routine${summary.routineCount === 1 ? '' : 's'}</span>
        </li>
        <li>
          <span class="import-summary-count">${summary.customActivityCount}</span>
          <span class="import-summary-label">custom ${summary.customActivityCount === 1 ? 'activity' : 'activities'}</span>
        </li>
        <li class="import-summary-skipped">
          <span class="import-summary-count">${summary.seededActivityCount}</span>
          <span class="import-summary-label">seeded ${summary.seededActivityCount === 1 ? 'activity' : 'activities'}</span>
          <span class="import-summary-note">(will be skipped — your current versions kept)</span>
        </li>
        <li>
          <span class="import-summary-count">${summary.sessionCount}</span>
          <span class="import-summary-label">session${summary.sessionCount === 1 ? '' : 's'}</span>
        </li>
      </ul>
    </div>
    
    <p class="import-confirm-question">How would you like to import?</p>
    
    <button type="button" class="import-action-btn" id="import-replace-btn">
      <div class="import-action-content">
        <div class="import-action-label">Replace All</div>
        <div class="import-action-hint">
          Wipe current data and import the backup. Best for restoring on a new device or after a reset.
        </div>
      </div>
    </button>
    
    <button type="button" class="import-action-btn" id="import-merge-btn">
      <div class="import-action-content">
        <div class="import-action-label">Merge</div>
        <div class="import-action-hint">
          Add to existing data. Items with matching IDs will be updated to the backup's version.
        </div>
      </div>
    </button>
    
    <div class="editor-actions">
      <button type="button" class="btn btn-secondary" id="import-cancel-btn">Cancel</button>
    </div>
  `;
  
  const modal = openModal({
    title: 'Import Backup',
    content,
  });
  
  content.querySelector('#import-cancel-btn').addEventListener('click', () => {
    closeModal(modal);
  });
  
  content.querySelector('#import-replace-btn').addEventListener('click', () => {
    closeModal(modal);
    setTimeout(() => {
      executeImport(data, summary, 'replace');
    }, 150);
  });
  
  content.querySelector('#import-merge-btn').addEventListener('click', () => {
    closeModal(modal);
    setTimeout(() => {
      executeImport(data, summary, 'merge');
    }, 150);
  });
}

