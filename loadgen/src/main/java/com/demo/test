export async function seedIfNeeded() {
  const alreadySeeded = await getMeta('seeded_v2');
  if (alreadySeeded) return;

  const [existingRoutines, existingActivities] = await Promise.all([
    getAllRoutines(),
    getAllActivities(),
  ]);

  const db = await getDB();
  let seededActivities = [];
  let seededRoutine = false;

  // 1. Seed activities if the activities store is empty
  //    (independent of routines — handles upgrade scenarios)
  if (existingActivities.length === 0) {
    seededActivities = createSeedActivities();
    const tx = db.transaction(STORE_ACTIVITIES, 'readwrite');
    for (const activity of seededActivities) {
      await tx.store.put(activity);
    }
    await tx.done;
  }

  // 2. Seed the sample routine only if NO routines exist
  //    (so we don't add duplicates for users who already have routines)
  if (existingRoutines.length === 0) {
    // Use freshly seeded activities, OR fetch existing ones if activities already existed
    const activitiesForRoutine = seededActivities.length > 0
      ? seededActivities
      : existingActivities;
    
    if (activitiesForRoutine.length > 0) {
      const sampleRoutine = createSampleRoutine(activitiesForRoutine);
      await db.put(STORE_ROUTINES, sampleRoutine);
      seededRoutine = true;
    }
  }

  if (seededActivities.length > 0 || seededRoutine) {
    console.log(
      `[HoldOn] Seeded ${seededActivities.length} activities${seededRoutine ? ' and 1 sample routine' : ''}.`
    );
  }

  await setMeta('seeded_v2', true);
}
