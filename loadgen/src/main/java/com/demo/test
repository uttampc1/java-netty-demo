      id: "authUser",
      text: "Are you an authorized user on someone else's credit card? (spouse, parent, or family member)",
      options: ["Yes", "No", "Not sure"]
    },
    {
      id: "knowScore",
      text: "Do you know your credit score?",
      options: ["Yes", "No"]
    },
    {
      id: "rejected",
      text: "Have you ever applied for credit and been rejected?",
      options: ["Yes", "No", "Never applied"]
    },
    {
      id: "bills",
      text: "Do you pay any regular bills? (rent, phone, utilities, subscriptions)",
      options: [
        "Yes, in my own name",
        "Yes, but under someone else's name",
        "No bills in my name"
      ]
    },
    {
      id: "goal",
      text: "What is your main goal right now?",
      options: [
        "Start building credit from scratch",
        "Understand why I was rejected",
        "Build credit independently from my spouse or family",
        "Improve the little credit I already have"
      ]
    }
  ];

  /* ── RESULT ENGINE ── */
  function getResult(ans) {
    if (ans.rejected === "Yes") return "rejected";
    if (ans.role === "Homemaker / not working outside home" &&
        ans.ownCard === "No") return "homemaker";
    if (ans.ownCard === "No" && ans.bankAccount === "No" &&
        ans.authUser === "No") return "zero";
    if (ans.ownCard === "No") return "thin";
    return "builder";
  }

  const results = {
    zero: {
      badge: "Starting From Zero",
      title: "You're starting at the very beginning — that's okay.",
      summary: "You don't have a credit file yet, and that's more common than you think. Here's a clear starting path.",
      steps: [
        { icon: "🏦", text: "Open a checking account first — it's your foundation." },
        { icon: "💳", text: "Apply for one beginner-safe product: a secured credit card." },
        { icon: "📅", text: "Set up autopay so you never miss a payment." },
        { icon: "📉", text: "Keep your balance below 30% of the card limit." },
        { icon: "⏳", text: "Wait 3–6 months, then check your progress." }
      ]
    },
    thin: {
      badge: "Thin File Beginner",
      title: "You have a small start — now build on it.",
      summary: "You have a little history but not much yet. The key is consistent, simple habits over the next few months.",
      steps: [
        { icon: "✅", text: "Pay every account on time — this matters most." },
        { icon: "📉", text: "Keep credit usage low (below 30%)." },
        { icon: "🚫", text: "Don't open multiple new accounts at once." },
        { icon: "🔍", text: "Check your credit report for any errors." },
        { icon: "⏳", text: "Give it 6 months of consistent habits before applying for anything new." }
      ]
    },
    rejected: {
      badge: "Rejected / Unsure",
      title: "A rejection is information — here's what to do next.",
      summary: "Being rejected stings, but it's fixable. The key is to stop random applications and take a targeted approach.",
      steps: [
        { icon: "🛑", text: "Stop applying for new cards right now — each hard pull hurts your score." },
        { icon: "📋", text: "Get your free credit report and look for errors or negative marks." },
        { icon: "🔒", text: "Consider a secured card — approval is much easier and it builds history." },
        { icon: "📅", text: "Make on-time payments for 3–6 months before applying again." },
        { icon: "📞", text: "Ask your bank about a credit-builder loan if a card isn't an option." }
      ]
    },
    homemaker: {
      badge: "Homemaker / Dependent Income",
      title: "Building your own credit is more important than you think.",
      summary: "Having credit only through a spouse or family member leaves you financially vulnerable. Here's how to build independently.",
      steps: [
        { icon: "👤", text: "Open a bank account in your own name if you haven't yet." },
        { icon: "💳", text: "Apply for a secured credit card in your own name — you can qualify even without income." },
        { icon: "🤝", text: "If you're an authorized user on a spouse's card, that helps — but your own card matters too." },
        { icon: "📅", text: "Pay your card on time every month, even if it's a small amount." },
        { icon: "🛡️", text: "Independent credit protects you — regardless of what changes in life." }
      ]
    },
    builder: {
      badge: "Early Builder",
      title: "You have a start — now build it the right way.",
      summary: "You already have some credit history. The goal now is to keep it clean and grow it steadily.",
      steps: [
        { icon: "✅", text: "Never miss a payment — perfect payment history is your biggest asset." },
        { icon: "📉", text: "Keep your utilization below 30% on all cards." },
        { icon: "🚫", text: "Avoid unnecessary hard inquiries — only apply when you really need to." },
        { icon: "📋", text: "Check your credit report once a year for errors." },
        { icon: "⏳", text: "Let your accounts age — older credit history helps your score." }
      ]
    }
  };

  /* ── STATE ── */
  let current = 0;
  const answers = {};

  /* ── RENDER QUESTION ── */
  function renderQuestion() {
    const q = questions[current];
    const totalQ = questions.length;
    const pct = ((current + 1) / totalQ * 100).toFixed(0);

    document.getElementById("stepCounter").textContent =
      `Question ${current + 1} of ${totalQ}`;
    document.getElementById("progressFill").style.width = pct + "%";

    const selected = answers[q.id] || null;

    document.getElementById("quizCard").innerHTML = `
      <p class="question-text">${q.text}</p>
      <div class="options">
        ${q.options.map(opt => `
          <button class="option-btn ${selected === opt ? 'selected' : ''}"
                  onclick="selectOption('${q.id}', this, '${escQ(opt)}')">
            <span class="option-dot"></span>
            ${opt}
          </button>
        `).join("")}
      </div>
      <div class="nav-buttons">
        ${current > 0
          ? `<button class="btn-back" onclick="goBack()">← Back</button>`
          : `<span></span>`}
        <button class="btn-next" id="nextBtn"
                ${selected ? "" : "disabled"}
                onclick="goNext()">
          ${current < totalQ - 1 ? "Next →" : "Get my plan →"}
        </button>
      </div>
    `;
  }

  function escQ(s) {
    return s.replace(/'/g, "\\'");
  }

  function selectOption(qId, btn, value) {
    answers[qId] = value;
    document.querySelectorAll(".option-btn").forEach(b => b.classList.remove("selected"));
    btn.classList.add("selected");
    document.getElementById("nextBtn").disabled = false;
  }

  function goNext() {
    if (!answers[questions[current].id]) return;
    current++;
    if (current >= questions.length) {
      renderResult();
    } else {
      renderQuestion();
    }
  }

  function goBack() {
    if (current > 0) { current--; renderQuestion(); }
  }

  /* ── RENDER RESULT ── */
  function renderResult() {
    const key = getResult(answers);
    const r = results[key];

    document.getElementById("stepCounter").textContent = "Your personalized plan";
    document.getElementById("progressFill").style.width = "100%";

    document.getElementById("quizCard").innerHTML = `
      <div class="result-card">
        <div class="result-badge">${r.badge}</div>
        <h2>${r.title}</h2>
        <p class="summary">${r.summary}</p>
        <ul class="steps-list">
          ${r.steps.map(s => `
            <li>
              <span class="step-icon">${s.icon}</span>
              <span>${s.text}</span>
            </li>
          `).join("")}
        </ul>

        <div class="email-section">
          <p>📬 Get your monthly credit tip — free, no spam, unsubscribe anytime.</p>
          <div class="email-row">
            <input type="email" id="emailInput" placeholder="you@email.com" />
            <button onclick="submitEmail()">Send me tips</button>
          </div>
          <p class="email-thanks" id="emailThanks">
            ✅ Got it! We'll send your first tip soon.
          </p>
        </div>

        <button class="restart-btn" onclick="restart()">
          ↩ Start over
        </button>
      </div>
    `;
  }

  function submitEmail() {
    const val = document.getElementById("emailInput").value.trim();
    if (!val || !val.includes("@")) {
      alert("Please enter a valid email address.");
      return;
    }
    /* TODO: send to backend / Mailchimp / Resend */
    document.querySelector(".email-row").style.display = "none";
    document.getElementById("emailThanks").style.display = "block";
  }

  function restart() {
    current = 0;
    Object.keys(answers).forEach(k => delete answers[k]);
    document.getElementById("stepCounter").textContent = "Question 1 of 8";
    renderQuestion();
  }

  /* ── INIT ── */
  renderQuestion();
</script>
</body>
</html>
