import * as cheerio from 'cheerio';

const OCHI_URL = 'https://search.ccb.state.or.us/search/ochi_search.aspx';

export interface HomeInspectorResult {
  found: boolean;
  licenseNumber: string;
  name: string;
  status: string;
  address: string;
  expiration: string;
}

export async function searchOregonHomeInspector(query: string): Promise<HomeInspectorResult> {
  const searchQuery = query.replace(/^HIC/i, '').trim();

  const noResult: HomeInspectorResult = {
    found: false,
    licenseNumber: searchQuery,
    name: '—',
    status: 'No Match',
    address: '—',
    expiration: '',
  };

  for (let attempt = 1; attempt <= 2; attempt++) {
    try {
      const resultHtml = await doSearch(OCHI_URL, searchQuery);

      const isResultsPage = resultHtml.includes('MainContent_inspectorCountLabel') ||
                            resultHtml.includes('MainContent_GridView2');

      if (!isResultsPage) {
        if (attempt === 1) {
          console.warn('[OCHI] POST returned form page, retrying...');
          continue;
        }
        console.error('[OCHI] POST returned form page on retry');
        return noResult;
      }

      const $ = cheerio.load(resultHtml);
      const countText = $('#MainContent_inspectorCountLabel').text().trim();
      const count = parseInt(countText, 10);

      if (!count || count === 0) {
        console.log(`[OCHI] Search "${searchQuery}" → No Match`);
        return noResult;
      }

      const table = $('#MainContent_GridView2');
      const firstDataRow = table.find('tr').eq(1);
      const cells = firstDataRow.find('td');

      if (cells.length < 3) {
        console.log(`[OCHI] Search "${searchQuery}" → No Match (not enough cells)`);
        return noResult;
      }

      const result: HomeInspectorResult = {
        found: true,
        licenseNumber: cells.eq(0).text().trim(),
        name: cells.eq(1).text().trim(),
        status: cells.eq(2).text().trim(),
        address: cells.length >= 4 ? cells.eq(3).text().trim() : '—',
        expiration: cells.length >= 5 ? cells.eq(4).text().trim() : '',
      };

      console.log(`[OCHI] Search "${searchQuery}" → ${result.status}`);
      return result;

    } catch (error) {
      if (attempt === 1) {
        console.warn('[OCHI] Attempt 1 failed, retrying:', error);
        continue;
      }
      console.error('[OCHI] Search failed:', error);
      return noResult;
    }
  }

  return noResult;
}

async function doSearch(url: string, query: string): Promise<string> {
  const pageRes = await fetch(url, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
      'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    },
  });

  if (!pageRes.ok) throw new Error(`GET ${url} returned ${pageRes.status}`);

  let cookieString = '';
  try {
    const setCookies = pageRes.headers.getSetCookie();
    cookieString = setCookies.map((c: string) => c.split(';')[0]).join('; ');
  } catch {
    const raw = pageRes.headers.get('set-cookie');
    if (raw) {
      cookieString = raw.split(',').map((c: string) => c.split(';')[0].trim()).join('; ');
    }
  }

  const pageHtml = await pageRes.text();
  const $page = cheerio.load(pageHtml);

  const viewState = $page('input[name="__VIEWSTATE"]').val() as string;
  const viewStateGen = $page('input[name="__VIEWSTATEGENERATOR"]').val() as string;
  const eventValidation = $page('input[name="__EVENTVALIDATION"]').val() as string;

  if (!viewState || !eventValidation) {
    throw new Error('Failed to extract form tokens');
  }

  const formData = new URLSearchParams();
  formData.append('__EVENTTARGET', '');
  formData.append('__EVENTARGUMENT', '');
  formData.append('__VIEWSTATE', viewState);
  formData.append('__VIEWSTATEGENERATOR', viewStateGen || '');
  formData.append('__EVENTVALIDATION', eventValidation);
  formData.append('ctl00$MainContent$activeToggle', 'All');
  formData.append('ctl00$MainContent$searchBox', query);
  formData.append('ctl00$MainContent$submitbtn', 'Search');
  formData.append('reCaptchaToken', '');

  const postHeaders: Record<string, string> = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    'Referer': url,
    'Origin': 'https://search.ccb.state.or.us',
  };

  if (cookieString) {
    postHeaders['Cookie'] = cookieString;
  }

  const searchRes = await fetch(url, {
    method: 'POST',
    headers: postHeaders,
    body: formData.toString(),
  });

  if (!searchRes.ok) throw new Error(`POST ${url} returned ${searchRes.status}`);

  return searchRes.text();
}

