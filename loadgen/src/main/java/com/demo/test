/**
 * WakeLockManager - keeps screen on during workouts.
 * Requires HTTPS (or localhost). Works iOS 16.4+, Android, desktop.
 */
class WakeLockManager {
  constructor({ onStatusChange } = {}) {
    this.wakeLock = null;
    this.wanted = false;          // true while a workout is active
    this.onStatusChange = onStatusChange || (() => {});
    this.supported = 'wakeLock' in navigator;

    // iOS releases the lock when page is hidden — re-acquire on return
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible' && this.wanted && !this.wakeLock) {
        this._acquire();
      }
    });
  }

  isSupported() {
    return this.supported;
  }

  async enable() {
    this.wanted = true;
    await this._acquire();
  }

  async disable() {
    this.wanted = false;
    if (this.wakeLock) {
      try { await this.wakeLock.release(); } catch (_) {}
      this.wakeLock = null;
    }
    this.onStatusChange({ active: false, supported: this.supported });
  }

  async _acquire() {
    if (!this.supported) {
      this.onStatusChange({ active: false, supported: false });
      return;
    }
    if (this.wakeLock) return; // already held

    try {
      this.wakeLock = await navigator.wakeLock.request('screen');
      this.wakeLock.addEventListener('release', () => {
        this.wakeLock = null;
        // If still wanted (e.g. OS released it), status reflects "not active"
        this.onStatusChange({ active: false, supported: true, released: true });
      });
      this.onStatusChange({ active: true, supported: true });
    } catch (err) {
      this.wakeLock = null;
      this.onStatusChange({ active: false, supported: true, error: err.message });
    }
  }
}

