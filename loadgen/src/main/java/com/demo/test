import { searchOregonCCB } from './oregon-ccb';
import { searchOregonLocksmith } from './oregon-locksmith';
import { searchOregonHomeInspector } from './oregon-home-inspector';

export interface OregonSearchResult {
  found: boolean;
  licenseNumber: string;
  name: string;
  status: string;
  address: string;
  expiration: string;
  licenseType: string;
}

export async function searchOregon(query: string): Promise<OregonSearchResult> {
  const trimmed = query.trim();

  // Route by format
  if (/OCLS$/i.test(trimmed)) {
    return searchAsLocksmith(trimmed);
  }

  if (/^HIC/i.test(trimmed)) {
    return searchAsHomeInspector(trimmed);
  }

  // Plain digits or other format — cascade
  // 1. General contractor (most common)
  const ccbResult = await searchOregonCCB(trimmed);
  if (ccbResult.found) {
    return {
      found: true,
      licenseNumber: ccbResult.licenseNumber,
      name: ccbResult.name,
      status: ccbResult.status,
      address: ccbResult.address,
      expiration: ccbResult.expiration,
      licenseType: 'General Contractor',
    };
  }

  // 2. Locksmith
  const locksmithResult = await searchOregonLocksmith(trimmed);
  if (locksmithResult.found) {
    return {
      found: true,
      licenseNumber: locksmithResult.licenseNumber,
      name: locksmithResult.name,
      status: locksmithResult.status,
      address: locksmithResult.address,
      expiration: locksmithResult.expiration,
      licenseType: 'Certified Locksmith',
    };
  }

  // 3. Home Inspector
  const inspectorResult = await searchOregonHomeInspector(trimmed);
  if (inspectorResult.found) {
    return {
      found: true,
      licenseNumber: inspectorResult.licenseNumber,
      name: inspectorResult.name,
      status: inspectorResult.status,
      address: inspectorResult.address,
      expiration: inspectorResult.expiration,
      licenseType: 'Certified Home Inspector',
    };
  }

  // Nothing found
  return {
    found: false,
    licenseNumber: trimmed,
    name: '—',
    status: 'No Match',
    address: '—',
    expiration: '',
    licenseType: '—',
  };
}

async function searchAsLocksmith(query: string): Promise<OregonSearchResult> {
  const result = await searchOregonLocksmith(query);
  if (result.found) {
    return {
      found: true,
      licenseNumber: result.licenseNumber,
      name: result.name,
      status: result.status,
      address: result.address,
      expiration: result.expiration,
      licenseType: 'Certified Locksmith',
    };
  }
  return {
    found: false,
    licenseNumber: query,
    name: '—',
    status: 'No Match',
    address: '—',
    expiration: '',
    licenseType: '—',
  };
}

