// src/views/aboutSection.js
/**
 * HoldOn — About Section (rendered inside Settings)
 * 
 * Static informational content. No interactions beyond
 * a future GitHub link (added post-deploy in Step 1.5).
 */

// __APP_VERSION__ is a build-time constant defined in vite.config.js
const APP_VERSION = typeof __APP_VERSION__ !== 'undefined' ? __APP_VERSION__ : 'dev';

export function renderAboutSection(container) {
  container.innerHTML = `
    <div class="about-section">
      <div class="about-header">
        <div class="about-name">HoldOn</div>
        <div class="about-version">Version ${APP_VERSION}</div>
        <div class="about-tagline">Simple timers for poses, holds &amp; reps.</div>
      </div>

      <div class="settings-divider"></div>

      <div class="about-block">
        <div class="about-block-title">🔒 Privacy</div>
        <p class="about-block-text">
          Your routines, activities, and workout history stay on your device.
          No accounts, no cloud sync, no tracking.
        </p>
        <p class="about-block-text about-block-subtle">
          When deployed publicly, anonymous and cookieless usage statistics
          may help improve the app — no personal data is ever collected.
        </p>
      </div>

      <div class="settings-divider"></div>

      <div class="about-block">
        <div class="about-block-title">⚙️ Built With</div>
        <ul class="about-tech-list">
          <li>Vite (build tool)</li>
          <li>IndexedDB (local storage)</li>
          <li>Service Workers (offline support)</li>
          <li>Vanilla JavaScript &amp; CSS</li>
          <li>❤️ for clean, simple UIs</li>
        </ul>
      </div>

      <div class="settings-divider"></div>

      <div class="about-block">
        <div class="about-block-title">📜 License</div>
        <p class="about-block-text">
          MIT License — free to use, modify, and share.
        </p>
      </div>

      <div class="settings-divider"></div>

      <div class="about-footer">
        <p class="about-footer-text">
          Made with care · <span class="about-footer-version">v${APP_VERSION}</span>
        </p>
      </div>
    </div>
  `;
}

// style
/* === Step 1.4.F.3.C — About Section === */

.about-section {
  padding: 4px 0;
}

.about-header {
  padding: 20px 16px 16px;
  text-align: center;
}

.about-name {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
  margin-bottom: 4px;
}

.about-version {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  font-variant-numeric: tabular-nums;
  margin-bottom: 8px;
}

.about-tagline {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.4;
}

.about-block {
  padding: 14px 16px;
}

.about-block-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6px;
}

.about-block-text {
  margin: 0 0 6px 0;
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
}

.about-block-text:last-child {
  margin-bottom: 0;
}

.about-block-subtle {
  font-size: 12px;
  font-style: italic;
}

.about-tech-list {
  margin: 0;
  padding-left: 20px;
  font-size: 13px;
  line-height: 1.7;
  color: var(--text-muted);
}

.about-tech-list li {
  padding-left: 4px;
}

.about-footer {
  padding: 16px;
  text-align: center;
  border-top: 1px solid var(--border);
  margin-top: 4px;
}

.about-footer-text {
  margin: 0;
  font-size: 12px;
  color: var(--text-muted);
}

.about-footer-version {
  font-family: 'SF Mono', Monaco, monospace;
  font-variant-numeric: tabular-nums;
}

