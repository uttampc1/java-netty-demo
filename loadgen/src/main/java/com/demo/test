const { calculateRoutineDuration, formatDuration } = await import('/src/utils/routineDuration.js')

// Simple 1-exercise routine
const simple = {
  id: 'test',
  exercises: [
    { id: 'a', name: 'Push-ups', workDuration: 30, restBetweenSets: 10, sets: 3 }
  ],
  restBetweenExercises: 15
};

const seconds = calculateRoutineDuration(simple)
console.log('Total seconds:', seconds)  
// Expected: 3 (prep) + 30×3 (work) + 10×2 (rests) = 113

console.log('Formatted:', formatDuration(seconds))
// Expected: "1 minute 53 seconds"

// 2
const multi = {
  id: 'test2',
  exercises: [
    { name: 'Superman', workDuration: 30, restBetweenSets: 10, sets: 5 },
    { name: 'Sumo', workDuration: 30, restBetweenSets: 10, sets: 5 },
    { name: 'Plank', workDuration: 30, restBetweenSets: 10, sets: 3 },
    { name: 'Dog', workDuration: 60, restBetweenSets: 10, sets: 3 },
    { name: 'Wall sit', workDuration: 30, restBetweenSets: 10, sets: 3 },
