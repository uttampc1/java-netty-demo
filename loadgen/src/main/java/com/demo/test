const { SessionEngine } = await import('/src/core/sessionEngine.js')

// Create a minimal test routine
const testRoutine = {
  id: 'test',
  title: 'Test Routine',
  restBetweenExercises: 5,
  exercises: [
    { id: 'ex1', name: 'Push-ups', workDuration: 4, restBetweenSets: 2, sets: 2 },
    { id: 'ex2', name: 'Squats', workDuration: 3, restBetweenSets: 0, sets: 1 },
  ],
};

const engine = new SessionEngine(testRoutine, { prepDuration: 2 });

console.log('Initial state:', engine.getState());


DONT RELOAD,
// Listen for all events
engine.on('phaseChange', (data) => {
  console.log(`📍 PHASE: ${data.from} → ${data.to}`, data.state);
});

engine.on('tick', (data) => {
  // Only log every full second to avoid spam
  if (data.timeRemaining === Math.floor(data.timeRemaining)) {
    console.log(`⏱  ${data.phase}: ${data.timeRemaining}s remaining`);
  }
});

engine.on('complete', (data) => {
  console.log(`🎉 COMPLETE! Total elapsed: ${data.totalElapsed}s`);
});

// Start the workout
engine.start();

// PAUSE test
const engine2 = new SessionEngine({
  id: 'p',
  title: 'Pause Test',
  restBetweenExercises: 0,
  exercises: [{ id: 'e', name: 'Hold', workDuration: 10, restBetweenSets: 0, sets: 1 }],
}, { prepDuration: 0 });

engine2.on('tick', (d) => {
  if (d.timeRemaining === Math.floor(d.timeRemaining)) {
    console.log(`⏱ ${d.timeRemaining}s`);
  }
});

engine2.start();

// After 3 seconds, pause
setTimeout(() => {
  console.log('⏸ PAUSING');
  engine2.pause();
}, 3500);

// After 6 seconds total (3 paused), resume
setTimeout(() => {
  console.log('▶ RESUMING');
  engine2.resume();
}, 6500);

// SKIP
const engine3 = new SessionEngine({
  id: 's',
  title: 'Skip Test',
  restBetweenExercises: 0,
  exercises: [
    { id: 'e1', name: 'First', workDuration: 30, restBetweenSets: 0, sets: 1 },
    { id: 'e2', name: 'Second', workDuration: 5, restBetweenSets: 0, sets: 1 },
  ],
}, { prepDuration: 0 });

engine3.on('phaseChange', (d) => console.log(`📍 ${d.from} → ${d.to}`, d.state.currentExercise?.name));

engine3.start();

setTimeout(() => {
  console.log('⏭ SKIP');
  engine3.skip();
}, 1500);

// EDGE case
// Single exercise, single set, no rests
const minimal = new SessionEngine({
  id: 'm',
  title: 'Minimal',
  restBetweenExercises: 0,
  exercises: [{ id: 'e', name: 'Only', workDuration: 3, restBetweenSets: 0, sets: 1 }],
}, { prepDuration: 0 });

minimal.on('phaseChange', (d) => console.log(`📍 ${d.from} → ${d.to}`));
minimal.on('complete', () => console.log('✅ Done'));
minimal.start();

// May steps
// Many sets, with rest
const reps = new SessionEngine({
  id: 'r',
  title: 'Reps',
  restBetweenExercises: 0,
  exercises: [{ id: 'e', name: 'Reps', workDuration: 2, restBetweenSets: 1, sets: 3 }],
}, { prepDuration: 0 });

reps.on('phaseChange', (d) => console.log(`📍 ${d.from} → ${d.to} (set ${d.state.currentSet})`));
reps.on('complete', () => console.log('✅ Done'));
reps.start();
