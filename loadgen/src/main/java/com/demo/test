/**
 * Centerline — Offline ready toast
 *
 * Shows a brief toast the first time the service worker finishes
 * installing, confirming the app is available offline.
 */

const STORAGE_KEY = 'cl_offline_ready_shown';

/**
 * Call once from main.js after init.
 * Listens for the service worker to become ready, then shows a toast
 * (but only once per install — not on every page load).
 */
export function listenForOfflineReady() {
  if (!('serviceWorker' in navigator)) return;

  navigator.serviceWorker.ready.then((registration) => {
    // Only show toast if this is a genuinely new install/activation,
    // not every time the page loads with an already-active SW.
    const alreadyShown = sessionStorage.getItem(STORAGE_KEY);
    if (alreadyShown) return;

    // Mark as shown for this browser session
    sessionStorage.setItem(STORAGE_KEY, '1');

    // Small delay so the app UI renders first
    setTimeout(() => showOfflineReadyToast(), 1500);
  });
}

function showOfflineReadyToast() {
  // Don't stack toasts
  if (document.getElementById('cl-offline-toast')) return;

  const toast = document.createElement('div');
  toast.id = 'cl-offline-toast';
  toast.setAttribute('role', 'status');
  toast.setAttribute('aria-live', 'polite');
  toast.innerHTML = `
    <span class="cl-toast-icon">✓</span>
    <span class="cl-toast-msg">App ready — works offline</span>
  `;

  Object.assign(toast.style, {
    position:        'fixed',
    bottom:          'calc(24px + env(safe-area-inset-bottom, 0px))',
    left:            '50%',
    transform:       'translateX(-50%) translateY(16px)',
    background:      '#2e7d32',
    color:           '#fff',
    padding:         '10px 18px',
    borderRadius:    '8px',
    fontSize:        '14px',
    fontWeight:      '500',
    display:         'flex',
    alignItems:      'center',
    gap:             '8px',
    zIndex:          '9999',
    opacity:         '0',
    transition:      'opacity 0.3s ease, transform 0.3s ease',
    whiteSpace:      'nowrap',
    boxShadow:       '0 2px 12px rgba(0,0,0,0.3)',
    pointerEvents:   'none',
  });

  document.body.appendChild(toast);

  // Animate in
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      toast.style.opacity = '1';
      toast.style.transform = 'translateX(-50%) translateY(0)';
    });
  });

  // Dismiss after 3 s
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateX(-50%) translateY(8px)';
    setTimeout(() => toast.remove(), 350);
  }, 3000);
}
