  align-items: center;
  justify-content: space-around;
  background-color: var(--bg-elevated);
  border-radius: var(--radius);
  padding: 18px 12px;
  margin-bottom: 24px;
  box-shadow: var(--shadow);
}

.summary-stat {
  text-align: center;
  flex: 1;
}

.summary-stat-value {
  font-size: 22px;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin-bottom: 2px;
}

.summary-stat-label {
  font-size: 12px;
  color: var(--text-muted);
  text-transform: lowercase;
}

.summary-stat-divider {
  width: 1px;
  height: 32px;
  background-color: var(--border);
}

/* Section Heading */
